---
import '../styles/global.css';
import { navItems, instItems, ui, localizePath, altLangPath, type Lang } from '../i18n';
import { cdnImg } from '../lib/img';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  image?: string;          // chemin absolu d'origine (ex. /images/projet/x.jpg)
}
const {
  title,
  description,
  lang = 'fr',
  image,
} = Astro.props;

const t = ui[lang];
const defaultDesc = lang === 'en'
  ? 'A platform for recording and showcasing the pedagogical innovation projects of the University of Geneva.'
  : "Plateforme de recensement et de valorisation des projets d'innovation pédagogique de l'Université de Genève.";
const desc = description ?? defaultDesc;
const fullTitle = `${title} — Innovations Pédagogiques · Université de Genève`;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(path: string): boolean {
  const lp = localizePath(path, lang);
  return currentPath === lp || currentPath.startsWith(lp + '/');
}

const frHref = altLangPath(currentPath, 'fr');
const enHref = altLangPath(currentPath, 'en');

// URLs absolues pour SEO / partage (Astro.site défini dans astro.config.mjs)
const site = Astro.site ?? new URL('https://innovuni.netlify.app');
const abs = (p: string) => new URL(p, site).href;
const canonical = abs(currentPath);
const ogImageSrc = image
  ? cdnImg(image, 1200, { h: 630, fit: 'cover', fm: 'jpg', q: 75 })
  : cdnImg('/images/sections/header.jpg', 1200, { h: 630, fit: 'cover', fm: 'jpg', q: 75 });
const ogImage = abs(ogImageSrc);

// Libellés du pied de page institutionnel UNIGE (les URL UNIGE gèrent elles-mêmes leur langue)
const fL = lang === 'en' ? {
  enroll: 'Enrol at UNIGE', informs: 'UNIGE keeps you informed', social: 'UNIGE social media',
  contact: 'Contact', plans: 'Building access maps', az: 'UNIGE from A to Z', cookies: 'Cookie policy and settings',
  immat: 'Enrolment', admin: 'Administrative procedures', ask: 'Ask a question',
  mobile: 'UNIGE Mobile', media: 'Media', jobs: 'Job offers', library: 'Library', calendar: 'Academic calendar',
  accred: 'Accreditation', top: 'Back to top',
} : {
  enroll: "S'inscrire à l'UNIGE", informs: "L'UNIGE vous informe", social: 'Médias sociaux UNIGE',
  contact: 'Contact', plans: "Plans d'accès aux bâtiments", az: "L'UNIGE de A à Z", cookies: 'Politique et configuration des cookies',
  immat: 'Immatriculations', admin: 'Démarches administratives', ask: 'Poser une question',
  mobile: 'UNIGE Mobile', media: 'Médias', jobs: "Offres d'emploi", library: 'Bibliothèque', calendar: 'Calendrier académique',
  accred: 'Accréditation', top: 'Haut de page',
};
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={desc} />
  <meta name="theme-color" content="#CF0063" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Canonical + alternances de langue -->
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="fr" href={abs(frHref)} />
  <link rel="alternate" hreflang="en" href={abs(enHref)} />
  <link rel="alternate" hreflang="x-default" href={abs(frHref)} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Innovations Pédagogiques · UNIGE" />
  <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'fr_FR'} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={desc} />
  <meta name="twitter:image" content={ogImage} />
</head>
<body>

  <!-- En-tête institutionnel UNIGE (charte officielle) -->
  <header class="unige-header" id="top">
    <div class="unige-header-inner">
      <a class="unige-logo" href="https://www.unige.ch" target="_blank" rel="noopener" aria-label="Université de Genève">
        <img src="/images/unige/unige-logo.svg" alt="Université de Genève" width="164" height="47" />
      </a>
      <nav class="unige-nav" aria-label={lang === 'en' ? 'University of Geneva navigation' : 'Navigation Université de Genève'}>
        {instItems.map(i => (
          <a href={lang === 'en' ? i.href_en : i.href_fr} target="_blank" rel="noopener">{lang === 'en' ? i.en : i.fr}</a>
        ))}
        <a href={lang === 'en' ? 'https://www.unige.ch/en/alumni/' : 'https://www.unige.ch/alumni/'} target="_blank" rel="noopener">Alumni</a>
      </nav>
      <div class="unige-tools">
        <span class="unige-langpick">
          <a href={frHref} class={lang === 'fr' ? 'on' : ''}>FR</a>
          <a href={enHref} class={lang === 'en' ? 'on' : ''}>EN</a>
        </span>
        <a class="unige-help" href="https://www.unige.ch/contact/" target="_blank" rel="noopener" aria-label={lang === 'en' ? 'Help / Contact' : 'Aide / Contact'}>?</a>
      </div>
    </div>
  </header>

  <!-- En-tête section Innovations Pédagogiques -->
  <header class="topbar">
    <nav class="nav" aria-label={t.navAria}>
      <a class="brand" href={localizePath('/', lang)} aria-label="Innovations Pédagogiques UNIGE">
        <span class="titles">
          <strong>Innovations Pédagogiques</strong>
          <span>{t.brandTagline}</span>
        </span>
      </a>

      <button class="burger" id="burger" type="button"
              aria-label={t.openMenu} aria-expanded="false" aria-controls="navlinks">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
      </button>

      <div class="navlinks" id="navlinks">
        {navItems.map(item => (
          <a href={localizePath(item.path, lang)} class={isActive(item.path) ? 'active' : ''}>
            {lang === 'en' ? item.en : item.fr}
          </a>
        ))}
      </div>
    </nav>
  </header>

  <!-- Contenu de la page -->
  <main>
    <slot />
  </main>

  <!-- Pied de page institutionnel UNIGE (charte officielle) -->
  <footer class="unige-footer" role="contentinfo">
    <div class="unige-footer-inner">
      <div class="unige-footer-grid">

        <!-- Col 1 : Université de Genève -->
        <div class="uf-col">
          <h2 class="uf-title">Université de Genève</h2>
          <address class="uf-address">
            24 rue du Général-Dufour<br />
            1211 Genève 4<br />
            T. +41 (0)22 379 71 11<br />
            F. +41 (0)22 379 11 34
          </address>
          <ul class="uf-links">
            <li><a href="https://www.unige.ch/contact/" target="_blank" rel="noopener">{fL.contact}</a></li>
            <li><a href="https://www.unige.ch/presse/plans" target="_blank" rel="noopener">{fL.plans}</a></li>
            <li><a href="https://www.unige.ch/-/a-z" target="_blank" rel="noopener">{fL.az}</a></li>
            <li><a href="https://www.unige.ch/-/cookies" target="_blank" rel="noopener">{fL.cookies}</a></li>
          </ul>
        </div>

        <!-- Col 2 : S'inscrire à l'UNIGE -->
        <div class="uf-col">
          <h2 class="uf-title">{fL.enroll}</h2>
          <ul class="uf-links">
            <li><a href="https://www.unige.ch/immatriculations/" target="_blank" rel="noopener">{fL.immat}</a></li>
            <li><a href="https://vie-de-campus.unige.ch/demarches-administratives" target="_blank" rel="noopener">{fL.admin}</a></li>
            <li><a href="https://admissions.unige.ch/kayako/index.php?/Tickets/Submit" target="_blank" rel="noopener">{fL.ask}</a></li>
          </ul>
        </div>

        <!-- Col 3 : L'UNIGE vous informe -->
        <div class="uf-col">
          <h2 class="uf-title">{fL.informs}</h2>
          <ul class="uf-links">
            <li><a href="https://www.unige.ch/mobile/" target="_blank" rel="noopener">{fL.mobile}</a></li>
            <li><a href="https://www.unige.ch/medias/" target="_blank" rel="noopener">{fL.media}</a></li>
            <li><a href="https://unige.ch/-/emplois" target="_blank" rel="noopener">{fL.jobs}</a></li>
            <li><a href="https://www.unige.ch/biblio/" target="_blank" rel="noopener">{fL.library}</a></li>
            <li><a href="https://www.unige.ch/calendrier" target="_blank" rel="noopener">{fL.calendar}</a></li>
          </ul>
        </div>

        <!-- Col 4 : Médias sociaux + accréditation -->
        <div class="uf-col">
          <h2 class="uf-title">{fL.social}</h2>
          <div class="uf-social">
            <a href="https://www.facebook.com/unigeneve" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="https://twitter.com/UNIGEnews" target="_blank" rel="noopener" aria-label="X (Twitter)">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://www.linkedin.com/company/university-of-geneva" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://www.youtube.com/channel/UCLVD78-qZV06ULrJ6eKJIiQ" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="4"/><path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="https://instagram.com/unigeneve/" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://www.unige.ch/rss/" target="_blank" rel="noopener" aria-label="RSS">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83C19.56 11.41 12.59 4.44 4 4.44zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83C13.9 14.53 9.47 10.1 4 10.1z"/></svg>
            </a>
            <a href="https://www.coursera.org/unige" target="_blank" rel="noopener" aria-label="Coursera">
              <svg viewBox="0 0 24 24"><text x="12" y="17" text-anchor="middle" font-size="17" fill="currentColor">∞</text></svg>
            </a>
            <a href="https://www.unige.ch/mobile/" target="_blank" rel="noopener" aria-label="UNIGE Mobile">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="7" y="2" width="10" height="20" rx="2"/><line x1="11" y1="18.5" x2="13" y2="18.5"/></svg>
            </a>
          </div>
          <h2 class="uf-accred-title">{fL.accred}</h2>
          <img class="uf-accred" src="/images/unige/accreditation.png"
               alt="Swiss Accreditation Council — Institution accréditée selon la LEHE pour 2022-2029" loading="lazy" />
        </div>
      </div>
    </div>

    <a class="uf-top" href="#top" aria-label={fL.top}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
    </a>
  </footer>

  <script>
    (function () {
      const b = document.getElementById('burger');
      const n = document.getElementById('navlinks');
      if (!b || !n) return;
      b.addEventListener('click', function () {
        const open = n.classList.toggle('open');
        b.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      n.addEventListener('click', function (e) {
        if ((e.target as Element).closest('a')) n.classList.remove('open');
      });
    })();
  </script>
</body>
</html>
