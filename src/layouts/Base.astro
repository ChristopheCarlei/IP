---
import '../styles/global.css';
import { navItems, ui, localizePath, altLangPath, type Lang } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}
const {
  title,
  description,
  lang = 'fr',
} = Astro.props;

const t = ui[lang];
const defaultDesc = lang === 'en'
  ? 'A platform for recording and showcasing the pedagogical innovation projects of the University of Geneva.'
  : "Plateforme de recensement et de valorisation des projets d'innovation pédagogique de l'Université de Genève.";
const desc = description ?? defaultDesc;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(path: string): boolean {
  const lp = localizePath(path, lang);
  return currentPath === lp || currentPath.startsWith(lp + '/');
}

const frHref = altLangPath(currentPath, 'fr');
const enHref = altLangPath(currentPath, 'en');
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title} — Innovations Pédagogiques · Université de Genève</title>
  <meta name="description" content={desc} />
  <meta name="theme-color" content="#CF0063" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- En-tête institutionnel UNIGE (charte officielle) -->
  <header class="unige-header" id="top">
    <div class="unige-header-inner">
      <a class="unige-logo" href="https://www.unige.ch" target="_blank" rel="noopener" aria-label="Université de Genève">
        <img src="/images/unige/unige-logo.svg" alt="Université de Genève" width="164" height="47" />
      </a>
      <nav class="unige-nav" aria-label="Navigation Université de Genève">
        <a href="https://www.unige.ch/universite/" target="_blank" rel="noopener">Université</a>
        <a href="https://www.unige.ch/facultes/" target="_blank" rel="noopener">Facultés</a>
        <a href="https://www.unige.ch/etudiants/" target="_blank" rel="noopener">Études</a>
        <a href="https://www.unige.ch/collaborateurs/" target="_blank" rel="noopener">Collaborateurs</a>
        <a href="https://www.unige.ch/services/" target="_blank" rel="noopener">Services</a>
        <a href="https://www.unige.ch/alumni/" target="_blank" rel="noopener">Alumni</a>
      </nav>
      <div class="unige-tools">
        <span class="unige-langpick">
          <a href={frHref} class={lang === 'fr' ? 'on' : ''}>FR</a>
          <a href={enHref} class={lang === 'en' ? 'on' : ''}>EN</a>
        </span>
        <a class="unige-help" href="https://www.unige.ch/contact/" target="_blank" rel="noopener" aria-label="Aide / Contact">?</a>
      </div>
    </div>
  </header>

  <!-- En-tête section Innovations Pédagogiques -->
  <header class="topbar">
    <nav class="nav" aria-label={t.navAria}>
      <a class="brand" href={localizePath('/', lang)} aria-label="Innovations Pédagogiques UNIGE">
        <span class="titles">
          <strong>Innovations Pédagogiques</strong>
          <span>{t.brandTagline}</span>
        </span>
      </a>

      <button class="burger" id="burger" type="button"
              aria-label={t.openMenu} aria-expanded="false" aria-controls="navlinks">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
      </button>

      <div class="navlinks" id="navlinks">
        {navItems.map(item => (
          <a href={localizePath(item.path, lang)} class={isActive(item.path) ? 'active' : ''}>
            {lang === 'en' ? item.en : item.fr}
          </a>
        ))}
      </div>
    </nav>
  </header>

  <!-- Contenu de la page -->
  <main>
    <slot />
  </main>

  <!-- Pied de page institutionnel UNIGE (charte officielle) -->
  <footer class="unige-footer" role="contentinfo">
    <div class="unige-footer-inner">
      <div class="unige-footer-grid">

        <!-- Col 1 : Université de Genève -->
        <div class="uf-col">
          <h2 class="uf-title">Université de Genève</h2>
          <address class="uf-address">
            24 rue du Général-Dufour<br />
            1211 Genève 4<br />
            T. +41 (0)22 379 71 11<br />
            F. +41 (0)22 379 11 34
          </address>
          <ul class="uf-links">
            <li><a href="https://www.unige.ch/contact/" target="_blank" rel="noopener">Contact</a></li>
            <li><a href="https://www.unige.ch/presse/plans" target="_blank" rel="noopener">Plans d'accès aux bâtiments</a></li>
            <li><a href="https://www.unige.ch/-/a-z" target="_blank" rel="noopener">L'UNIGE de A à Z</a></li>
            <li><a href="https://www.unige.ch/-/cookies" target="_blank" rel="noopener">Politique et configuration des cookies</a></li>
          </ul>
        </div>

        <!-- Col 2 : S'inscrire à l'UNIGE -->
        <div class="uf-col">
          <h2 class="uf-title">S'inscrire à l'UNIGE</h2>
          <ul class="uf-links">
            <li><a href="https://www.unige.ch/immatriculations/" target="_blank" rel="noopener">Immatriculations</a></li>
            <li><a href="https://vie-de-campus.unige.ch/demarches-administratives" target="_blank" rel="noopener">Démarches administratives</a></li>
            <li><a href="https://admissions.unige.ch/kayako/index.php?/Tickets/Submit" target="_blank" rel="noopener">Poser une question</a></li>
          </ul>
        </div>

        <!-- Col 3 : L'UNIGE vous informe -->
        <div class="uf-col">
          <h2 class="uf-title">L'UNIGE vous informe</h2>
          <ul class="uf-links">
            <li><a href="https://www.unige.ch/mobile/" target="_blank" rel="noopener">UNIGE Mobile</a></li>
            <li><a href="https://www.unige.ch/medias/" target="_blank" rel="noopener">Médias</a></li>
            <li><a href="https://unige.ch/-/emplois" target="_blank" rel="noopener">Offres d'emploi</a></li>
            <li><a href="https://www.unige.ch/biblio/" target="_blank" rel="noopener">Bibliothèque</a></li>
            <li><a href="https://www.unige.ch/calendrier" target="_blank" rel="noopener">Calendrier académique</a></li>
          </ul>
        </div>

        <!-- Col 4 : Médias sociaux + accréditation -->
        <div class="uf-col">
          <h2 class="uf-title">Médias sociaux UNIGE</h2>
          <div class="uf-social">
            <a href="https://www.facebook.com/unigeneve" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="https://twitter.com/UNIGEnews" target="_blank" rel="noopener" aria-label="X (Twitter)">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://www.linkedin.com/company/university-of-geneva" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://www.youtube.com/channel/UCLVD78-qZV06ULrJ6eKJIiQ" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="4"/><path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="https://instagram.com/unigeneve/" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://www.unige.ch/rss/" target="_blank" rel="noopener" aria-label="RSS">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83C19.56 11.41 12.59 4.44 4 4.44zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83C13.9 14.53 9.47 10.1 4 10.1z"/></svg>
            </a>
            <a href="https://www.coursera.org/unige" target="_blank" rel="noopener" aria-label="Coursera">
              <svg viewBox="0 0 24 24"><text x="12" y="17" text-anchor="middle" font-size="17" fill="currentColor">∞</text></svg>
            </a>
            <a href="https://www.unige.ch/mobile/" target="_blank" rel="noopener" aria-label="UNIGE Mobile">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="7" y="2" width="10" height="20" rx="2"/><line x1="11" y1="18.5" x2="13" y2="18.5"/></svg>
            </a>
          </div>
          <h2 class="uf-accred-title">Accréditation</h2>
          <img class="uf-accred" src="/images/unige/accreditation.png"
               alt="Swiss Accreditation Council — Institution accréditée selon la LEHE pour 2022-2029" loading="lazy" />
        </div>
      </div>
    </div>

    <a class="uf-top" href="#top" aria-label="Haut de page">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
    </a>
  </footer>

  <script>
    (function () {
      const b = document.getElementById('burger');
      const n = document.getElementById('navlinks');
      if (!b || !n) return;
      b.addEventListener('click', function () {
        const open = n.classList.toggle('open');
        b.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      n.addEventListener('click', function (e) {
        if ((e.target as Element).closest('a')) n.classList.remove('open');
      });
    })();
  </script>
</body>
</html>
