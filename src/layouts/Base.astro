---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'fr' | 'en';
}
const {
  title,
  description = "Plateforme de recensement et de valorisation des projets d'innovation pédagogique de l'Université de Genève.",
  lang = 'fr',
} = Astro.props;

const navItems = [
  { href: '/catalogue',   fr: 'Catalogue',    en: 'Catalogue' },
  { href: '/ia',          fr: 'IA',            en: 'AI' },
  { href: '/videos',      fr: 'Vidéos',        en: 'Videos' },
  { href: '/soutien',     fr: 'Soutien',       en: 'Support' },
  { href: '/observation', fr: 'Observation',   en: 'Observation' },
  { href: '/prix',        fr: 'Prix',          en: 'Awards' },
  { href: '/commission',  fr: 'Commission',    en: 'Committee' },
];

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title} — Innovations Pédagogiques · Université de Genève</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#CF0063" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- Filet rose institutionnel 5 px -->
  <div class="topstrip"></div>

  <!-- En-tête sticky -->
  <header class="topbar">
    <nav class="nav" aria-label="Navigation principale">
      <a class="brand" href="/" aria-label="Accueil — Innovations Pédagogiques UNIGE">
        <span class="wordmark">
          <span class="u">UNIGE</span>
          <span class="g">Université de Genève</span>
        </span>
        <span class="divider" aria-hidden="true"></span>
        <span class="titles">
          <strong>Innovations</strong>
          <span>Pédagogiques</span>
        </span>
      </a>

      <button class="burger" id="burger" type="button"
              aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="navlinks">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
      </button>

      <div class="navlinks" id="navlinks">
        {navItems.map(item => {
          const isActive = currentPath === item.href || (currentPath.startsWith(item.href + '/'));
          return (
            <a href={item.href} class={isActive ? 'active' : ''}>
              {lang === 'en' ? item.en : item.fr}
            </a>
          );
        })}
        <span class="langpick">
          <a href="/" class={lang === 'fr' ? 'on' : ''}>FR</a>
          <a href="/en" class={lang === 'en' ? 'on' : ''}>EN</a>
        </span>
      </div>
    </nav>
  </header>

  <!-- Contenu de la page -->
  <main>
    <slot />
  </main>

  <!-- Pied de page -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <span class="wordmark">
            <span class="u">UNIGE</span>
            <span class="g">Université de Genève</span>
          </span>
          <p class="about">
            Plateforme de recensement et de valorisation des projets d'innovation
            pédagogique de l'Université de Genève. Une initiative du Pôle SEA
            et de la Commission d'Innovation Pédagogique.
          </p>
        </div>
        <div>
          <h4>Contact</h4>
          <address>
            Pôle SEA<br />
            24 rue du Général-Dufour<br />
            1211 Genève 4<br />
            <a class="mail" href="mailto:sea@unige.ch">sea@unige.ch</a>
          </address>
        </div>
        <div>
          <h4>Liens</h4>
          <ul>
            <li><a href="https://www.unige.ch" target="_blank" rel="noopener">unige.ch</a></li>
            <li><a href="/catalogue">Catalogue des projets</a></li>
            <li><a href="/observation">Observation entre pairs</a></li>
            <li><a href="/prix">Prix de la pédagogie</a></li>
            <li><a href="/admin/">Administration CMS</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-base">
        <span>© {new Date().getFullYear()} Université de Genève</span>
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
           target="_blank" rel="noopener"
           style="color:var(--faint);font-weight:600">CC BY-NC-SA 4.0</a>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      const b = document.getElementById('burger');
      const n = document.getElementById('navlinks');
      if (!b || !n) return;
      b.addEventListener('click', function () {
        const open = n.classList.toggle('open');
        b.setAttribute('aria-expanded', open ? 'true' : 'false');
        b.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
      });
      n.addEventListener('click', function (e) {
        if ((e.target as Element).closest('a')) n.classList.remove('open');
      });
    })();
  </script>
</body>
</html>
