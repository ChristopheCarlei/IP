---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

function getFacVar(fac?: string | null): string {
  if (!fac) return 'var(--rose)';
  const f = fac.toUpperCase();
  if (f.includes('FPSE') || f.includes('PSE') || f.includes('PSYCH')) return 'var(--fac-fapse)';
  if (f.includes('GSEM'))                                               return 'var(--fac-gsem)';
  if (f.includes('FTI')  || f.includes('TRAD'))                        return 'var(--fac-fti)';
  if (f.includes('SCIEN') && !f.includes('SOC'))                       return 'var(--fac-sciences)';
  if (f.includes('MED')  || f.includes('MÉD'))                         return 'var(--fac-medecine)';
  if (f.includes('DROIT')|| f.includes('LAW'))                         return 'var(--fac-droit)';
  if (f.includes('LETTR'))                                              return 'var(--fac-lettres)';
  if (f.includes('SOC')  || f.includes('SDS'))                         return 'var(--fac-sds)';
  if (f.includes('THEO') || f.includes('THÉO'))                        return 'var(--fac-theologie)';
  return 'var(--rose)';
}
function isLightFac(fac?: string | null): boolean {
  const f = fac?.toUpperCase() ?? '';
  return f.includes('SOC') || f.includes('SDS');
}

const facVar = getFacVar(d.faculty);
const light  = isLightFac(d.faculty);

// Images secondaires pour le carousel
// Si vidéo présente : toutes les images sont secondaires ; sinon : images[1+]
const carouselImages: string[] = d.images
  ? (d.youtube ? d.images : d.images.slice(1))
  : [];

const hasCarousel = carouselImages.length > 0;
---
<Base title={d.title} description={d.description_short}>
<style>
/* ---- Fiche projet ---------------------------------------- */

/* Fil d'Ariane */
.crumb-bar{background:var(--bg-soft);border-bottom:1px solid var(--line)}
.crumb{width:var(--content);margin:auto;padding:14px 0;font-size:13px;color:var(--faint);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.crumb a{text-decoration:none;color:inherit}
.crumb a:hover{color:var(--rose)}
.crumb .sep{opacity:.5}
.crumb .cur{color:var(--muted);font-weight:600}

/* ---- Carte principale ---- */
.proj-card{width:var(--content);margin:clamp(20px,3vw,36px) auto 0;background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}

/* En-tête : photo + titre + équipe */
.proj-header{display:flex;align-items:flex-start;gap:28px;padding:28px 28px 24px;border-bottom:1px solid var(--line);position:relative}
.proj-header-photo{width:160px;height:160px;flex-shrink:0;border-radius:var(--radius-sm);object-fit:cover;object-position:center 15%;border:1px solid var(--line)}
.proj-header-photo-placeholder{width:160px;height:160px;flex-shrink:0;border-radius:var(--radius-sm);background:var(--fac,var(--rose));display:flex;align-items:center;justify-content:center}
.proj-header-photo-placeholder span{font-size:52px;font-weight:800;color:rgba(255,255,255,.28);letter-spacing:-.02em}
.proj-header-text{flex:1;min-width:0;padding-top:4px}
.proj-header-text h1{font-size:clamp(26px,3.5vw,42px);font-weight:800;letter-spacing:-.025em;line-height:1.05;margin:0 0 10px;color:var(--ink)}
.proj-header-text h1 .word1{color:var(--rose)}
.proj-header-text .author-main{font-size:17px;font-weight:800;color:var(--ink);margin:0 0 5px}
.proj-header-text .author-team{font-size:15px;color:var(--muted);margin:0}
.proj-header-btn{position:absolute;bottom:18px;right:24px;background:var(--ink);color:#fff;font-size:13px;font-weight:700;padding:9px 16px;border-radius:6px;text-decoration:none;white-space:nowrap;display:inline-flex;align-items:center;gap:6px}
.proj-header-btn:hover{background:var(--rose)}
.tagrow{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:10px}
.tag{font-size:12px;font-weight:800;padding:4px 12px;border-radius:999px;white-space:nowrap}
.tag.axe{color:var(--rose-ink);background:var(--bg-rose)}
.tag.prix{color:#fff;display:inline-flex;align-items:center;gap:5px;background:var(--ink)}
.tag.archive{color:var(--ink);background:#FEF3C7;border:1px solid #FDE68A}

/* Corps : média gauche + description droite */
.proj-card-body{display:grid;grid-template-columns:1fr 1fr;gap:0;min-height:260px}

/* Panneau gauche : vidéo ou image principale */
.proj-media{border-right:1px solid var(--line);display:flex;flex-direction:column;position:relative;overflow:hidden;background:#000}
.proj-media .media-embed{width:100%;height:100%;position:relative}
.proj-media .media-embed iframe{width:100%;height:100%;border:0;display:block;min-height:260px}
.proj-media img.main-img{width:100%;height:100%;object-fit:cover;display:block}
.proj-media .media-placeholder{width:100%;height:100%;min-height:260px;background:var(--fac,var(--rose));display:flex;align-items:center;justify-content:center}
.proj-media .media-placeholder span{font-size:72px;font-weight:800;color:rgba(255,255,255,.2);letter-spacing:-.02em}

/* Côté description */
.proj-desc{padding:24px 28px;display:flex;flex-direction:column;gap:12px}
.proj-desc .desc-label{font-size:clamp(20px,2.2vw,26px);font-weight:800;color:var(--fac,var(--rose));line-height:1}
.proj-desc .desc-text{font-size:15.5px;line-height:1.65;color:var(--ink);font-style:italic;margin:0}
.proj-desc .desc-meta{margin-top:8px;display:flex;flex-direction:column;gap:8px;font-size:14.5px}
.proj-desc .desc-meta .row{display:flex;gap:6px;align-items:baseline;flex-wrap:wrap}
.proj-desc .desc-meta strong{color:var(--ink);font-weight:700;white-space:nowrap}
.proj-desc .desc-meta a{color:var(--fac,var(--rose));font-weight:600;text-decoration:none}
.proj-desc .desc-meta a:hover{text-decoration:underline}
.proj-desc .desc-meta span{color:var(--muted)}

/* Barre infos colorée */
.proj-card-foot{background:var(--fac,var(--rose));display:flex;align-items:stretch}
.proj-card-foot.light .foot-item{color:var(--ink)}
.foot-item{flex:1;display:flex;align-items:center;gap:10px;padding:14px 20px;color:#fff;font-size:14px;font-weight:700}
.foot-item:not(:last-child){border-right:1px solid rgba(255,255,255,.2)}
.foot-item svg{width:20px;height:20px;flex-shrink:0;opacity:.85}
.foot-item .fi-label{font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;opacity:.75;margin-bottom:2px}
.foot-item .fi-val{font-size:14px;font-weight:700;line-height:1.2}

/* ---- Carousel illustrations secondaires ---- */
.carousel-wrap{width:var(--content);margin:24px auto 0;background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
.carousel-head{padding:16px 20px 14px;border-bottom:1px solid var(--line);font-size:13px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--rose)}
.carousel-stage{position:relative;overflow:hidden;background:#111}
.carousel-track{display:flex;transition:transform .35s cubic-bezier(.4,0,.2,1)}
.carousel-slide{flex-shrink:0;width:100%;display:flex;justify-content:center;align-items:center;background:#111}
.carousel-slide img{width:100%;max-height:420px;object-fit:contain;display:block}
.carousel-btn{position:absolute;top:50%;transform:translateY(-50%);z-index:10;background:rgba(255,255,255,.92);border:none;border-radius:50%;width:44px;height:44px;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.18);transition:background .15s}
.carousel-btn:hover{background:#fff}
.carousel-btn svg{width:18px;height:18px;color:var(--ink)}
.carousel-btn.prev{left:14px}
.carousel-btn.next{right:14px}
.carousel-dots{display:flex;justify-content:center;gap:8px;padding:14px 0}
.carousel-dots button{width:9px;height:9px;border-radius:50%;border:none;background:var(--line-strong);cursor:pointer;padding:0;transition:background .15s,transform .15s}
.carousel-dots button.on{background:var(--fac,var(--rose));transform:scale(1.2)}
.carousel-caption{text-align:center;font-size:13px;color:var(--faint);padding:0 20px 14px;min-height:20px}

/* ---- Corps (accordéon + annexes) ---- */
.body-wrap{width:var(--content);margin:24px auto clamp(48px,6vw,72px)}

.accordion{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
details.acc-item{border-radius:var(--radius-sm);overflow:hidden}
details.acc-item summary{list-style:none;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 28px;background:#F2F2F2;cursor:pointer;font-size:18px;font-weight:400;color:var(--ink);letter-spacing:-.01em;user-select:none}
details.acc-item summary::-webkit-details-marker{display:none}
details.acc-item summary .acc-chevron{flex-shrink:0;transition:transform .22s ease;width:20px;height:20px;color:#555}
details.acc-item[open] summary .acc-chevron{transform:rotate(180deg)}
details.acc-item summary:hover{background:#EAEAEA}
.acc-body{padding:22px 28px 26px;border:1px solid var(--line);border-top:0;border-radius:0 0 var(--radius-sm) var(--radius-sm)}
.acc-body h3{font-size:16px;font-weight:700;margin:18px 0 6px;color:var(--ink)}
.acc-body h3:first-child{margin-top:0}
.acc-body p{color:var(--muted);font-size:15.5px;line-height:1.7;margin:0 0 13px}
.acc-body p:last-child{margin-bottom:0}
.acc-body ul{margin:0 0 13px;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:8px}
.acc-body ul li{position:relative;padding-left:22px;color:var(--muted);font-size:15.5px;line-height:1.6}
.acc-body ul li::before{content:"";position:absolute;left:4px;top:9px;width:7px;height:7px;border-radius:2px;background:var(--fac,var(--rose))}
.acc-body blockquote{margin:16px 0;padding:4px 0 4px 18px;border-left:3px solid var(--fac,var(--rose));font-size:15.5px;line-height:1.6;color:var(--ink);font-style:italic}
.acc-body blockquote p{color:var(--ink);font-style:italic;margin:0}
.acc-body a{color:var(--fac,var(--rose));font-weight:600;text-decoration:none}
.acc-body a:hover{text-decoration:underline}

/* Prose sans h2 */
.prose{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:clamp(22px,3vw,36px);box-shadow:var(--shadow)}
.prose h3{font-size:17px;font-weight:700;margin:20px 0 7px;color:var(--ink)}
.prose p{color:var(--muted);font-size:15.5px;line-height:1.7;margin:0 0 13px}
.prose ul{margin:0 0 13px;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:8px}
.prose ul li{position:relative;padding-left:22px;color:var(--muted);font-size:15.5px;line-height:1.6}
.prose ul li::before{content:"";position:absolute;left:4px;top:9px;width:7px;height:7px;border-radius:2px;background:var(--fac,var(--rose))}
.prose blockquote{margin:20px 0;padding:4px 0 4px 18px;border-left:3px solid var(--fac,var(--rose));font-size:16px;line-height:1.6;color:var(--ink);font-style:italic}
.prose blockquote p{color:var(--ink);font-style:italic;margin:0}

/* Section Annexes (rendue hors accordéon) */
.annexes{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:28px 32px;box-shadow:var(--shadow);margin-top:24px}
.annexes-title{font-size:22px;font-weight:800;letter-spacing:-.01em;color:var(--ink);margin:0 0 6px}
.annexes-rule{border:0;border-top:1px solid var(--line);margin:0 0 20px}
.annexes-links{display:flex;flex-direction:column;gap:10px}
.annexes-links a{display:inline-flex;align-items:center;gap:10px;color:var(--rose);font-weight:600;font-size:15.5px;text-decoration:none}
.annexes-links a:hover{text-decoration:underline}
.annexes-links a svg{width:20px;height:20px;flex-shrink:0;color:var(--ink);opacity:.6}

/* Observation */
.obs{margin-top:24px;border-radius:var(--radius);padding:18px 22px;background:color-mix(in srgb,var(--fac-sciences) 7%,#fff);border:1px solid color-mix(in srgb,var(--fac-sciences) 28%,#fff)}
.obs strong{display:flex;align-items:center;gap:9px;color:var(--fac-sciences);font-size:15px;font-weight:800;margin-bottom:5px}
.obs strong svg{width:18px;height:18px;flex-shrink:0}
.obs p{color:var(--muted);font-size:14px;margin:0}
.obs p a{color:var(--fac-sciences);font-weight:700}

/* Retour */
.back-link{display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:700;color:var(--muted);text-decoration:none;margin-bottom:20px}
.back-link:hover{color:var(--rose)}

@media(max-width:860px){
  .proj-card-body{grid-template-columns:1fr}
  .proj-media{border-right:0;border-bottom:1px solid var(--line)}
  .proj-card-foot{flex-wrap:wrap}
  .foot-item{flex:1 1 45%}
  .proj-header{flex-wrap:wrap}
  .proj-header-btn{position:static;margin-top:12px;align-self:flex-start}
}
@media(max-width:560px){
  .foot-item{flex:1 1 100%}
  .proj-header-photo,.proj-header-photo-placeholder{width:120px;height:120px}
}
</style>

<!-- Fil d'Ariane -->
<div class="crumb-bar">
  <nav class="crumb" aria-label="Fil d'Ariane">
    <a href="/">Accueil</a>
    <span class="sep">/</span>
    <a href="/catalogue">Catalogue</a>
    <span class="sep">/</span>
    <span class="cur">{d.title}</span>
  </nav>
</div>

<div style={`--fac:${facVar}`}>

<!-- ===== Carte principale ===== -->
<div class="proj-card">

  <!-- En-tête : photo enseignant + titre + équipe -->
  <div class="proj-header">
    {d.photo
      ? <img src={d.photo} alt={d.author ?? d.title} class="proj-header-photo" />
      : <div class="proj-header-photo-placeholder">
          <span>{(d.author ?? d.title ?? '').split(' ').slice(0,2).map((w: string) => w[0] ?? '').join('').toUpperCase()}</span>
        </div>
    }
    <div class="proj-header-text">
      <h1>
        {(() => {
          const words = d.title.split(' ');
          if (words.length <= 1) return d.title;
          return <>{<span class="word1">{words[0]}</span>}{' '}{words.slice(1).join(' ')}</>;
        })()}
      </h1>
      {d.author && <p class="author-main">{d.author}</p>}
      {d.team   && <p class="author-team">{d.team}</p>}
      <div class="tagrow">
        {d.category && <span class="tag axe">{d.category}</span>}
        {d.award && (
          <span class="tag prix">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
              <path d="M12 2l2.4 5 5.6.6-4.2 3.8 1.2 5.6L12 19.8 6.9 17 8 11.4 3.8 7.6l5.6-.6z"/>
            </svg>
            {d.award}
          </span>
        )}
        {d.status === 'archivé' && <span class="tag archive">Archivé</span>}
      </div>
    </div>
    <a class="proj-header-btn" href="/catalogue">
      Tous les projets
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </a>
  </div>

  <!-- Corps : média principal gauche + description droite -->
  <div class="proj-card-body">

    <!-- Média principal : vidéo > première image > placeholder -->
    <div class="proj-media">
      {d.youtube ? (
        <div class="media-embed">
          <iframe src={d.youtube} allowfullscreen loading="lazy" title={`Vidéo — ${d.title}`} />
        </div>
      ) : (d.images && d.images.length > 0) ? (
        <img src={d.images[0]} alt={d.title} class="main-img" loading="lazy" />
      ) : (
        <div class="media-placeholder">
          <span>{(d.author ?? d.title ?? '').split(' ').slice(0,2).map((w: string) => w[0] ?? '').join('').toUpperCase()}</span>
        </div>
      )}
    </div>

    <!-- Description -->
    <div class="proj-desc">
      <div class="desc-label">Projet</div>
      {d.description_short && <p class="desc-text">{d.description_short}</p>}
      <div class="desc-meta">
        {d.course && (
          <div class="row">
            <strong>Cours :</strong>
            <span><a href="#">{d.course}</a>{d.level ? ` / ${d.level}` : ''}</span>
          </div>
        )}
        {d.contact && (
          <div class="row">
            <strong>Contact :</strong>
            <a href={`mailto:${d.contact}`}>{d.contact}</a>
          </div>
        )}
        {d.author && !d.course && !d.contact && (
          <div class="row"><strong>Responsable :</strong><span>{d.author}</span></div>
        )}
        {d.year && (
          <div class="row"><strong>Depuis :</strong><span>{d.year}</span></div>
        )}
      </div>
    </div>
  </div>

  <!-- Barre infos colorée -->
  <div class={`proj-card-foot${light ? ' light' : ''}`}>
    {d.category && (
      <div class="foot-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
        </svg>
        <div><div class="fi-label">Axe</div><div class="fi-val">{d.category}</div></div>
      </div>
    )}
    {d.innovation_type && (
      <div class="foot-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a7 7 0 0 1 7 7c0 3-1.8 5.4-4.5 6.5V17a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1v-1.5C6.8 14.4 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M9 21h6"/>
        </svg>
        <div><div class="fi-label">Type d'innovation</div><div class="fi-val">{d.innovation_type}</div></div>
      </div>
    )}
    {d.students && (
      <div class="foot-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <div><div class="fi-label">Étudiant·es</div><div class="fi-val">{d.students}</div></div>
      </div>
    )}
  </div>
</div>

<!-- ===== Carousel illustrations secondaires ===== -->
{hasCarousel && (
  <div class="carousel-wrap" id="carousel-wrap">
    <div class="carousel-head">Illustrations</div>
    <div class="carousel-stage">
      <div class="carousel-track" id="carousel-track">
        {carouselImages.map((img, i) => (
          <div class="carousel-slide" data-index={i}>
            <img src={img} alt={`Illustration ${i + 1} — ${d.title}`} loading="lazy" />
          </div>
        ))}
      </div>
      {carouselImages.length > 1 && (
        <>
          <button class="carousel-btn prev" id="carousel-prev" aria-label="Image précédente">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="carousel-btn next" id="carousel-next" aria-label="Image suivante">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </>
      )}
    </div>
    {carouselImages.length > 1 && (
      <div class="carousel-dots" id="carousel-dots">
        {carouselImages.map((_, i) => (
          <button class={i === 0 ? 'on' : ''} data-i={i} aria-label={`Image ${i + 1}`}></button>
        ))}
      </div>
    )}
    <div class="carousel-caption" id="carousel-caption"></div>
  </div>
)}

<!-- ===== Corps étendu (accordéon + annexes) ===== -->
<div class="body-wrap">
  <a class="back-link" href="/catalogue">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 19l-7-7 7-7"/>
    </svg>
    Retour au catalogue
  </a>

  <!-- Contenu Markdown → accordéon + annexes -->
  <div class="prose" id="proj-prose">
    <Content />
  </div>

  {d.observation_accepted && (
    <div class="obs">
      <strong>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2.5 12C4 7.9 7.7 5 12 5s8 2.9 9.5 7c-1.5 4.1-5.2 7-9.5 7s-8-2.9-9.5-7z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        Observation entre pairs
      </strong>
      <p>Cet·te enseignant·e accepte que des collègues observent son cours. <a href="/observation">En savoir plus →</a></p>
    </div>
  )}
</div>

</div><!-- /--fac wrapper -->

<script>
/* ---- Carousel ---- */
(function () {
  const track  = document.getElementById('carousel-track') as HTMLElement | null;
  const dots   = document.querySelectorAll<HTMLButtonElement>('#carousel-dots button');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  if (!track) return;

  const slides = track.querySelectorAll('.carousel-slide');
  let current = 0;
  const total = slides.length;

  function go(n: number) {
    current = (n + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('on', i === current));
  }

  prevBtn?.addEventListener('click', () => go(current - 1));
  nextBtn?.addEventListener('click', () => go(current + 1));
  dots.forEach((btn, i) => btn.addEventListener('click', () => go(i)));

  // Swipe touch
  let tx = 0;
  track.parentElement?.addEventListener('touchstart', (e: TouchEvent) => { tx = e.touches[0].clientX; }, { passive: true });
  track.parentElement?.addEventListener('touchend',   (e: TouchEvent) => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 40) go(dx < 0 ? current + 1 : current - 1);
  }, { passive: true });
})();

/* ---- Accordéon + extraction Annexes ---- */
(function () {
  const prose = document.getElementById('proj-prose');
  if (!prose) return;

  const children = Array.from(prose.childNodes);
  const h2s = prose.querySelectorAll('h2');
  if (!h2s.length) return;

  function chevron() {
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '1.8');
    svg.setAttribute('stroke-linecap', 'round');
    svg.setAttribute('stroke-linejoin', 'round');
    svg.classList.add('acc-chevron');
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', 'M6 9l6 6 6-6');
    svg.appendChild(path);
    return svg;
  }

  // Séparer les nœuds en sections h2
  const sections: { title: string; nodes: Node[] }[] = [];
  let before: Node[] = [];
  let currentTitle: string | null = null;
  let currentNodes: Node[] = [];

  children.forEach(node => {
    if (node.nodeType === Node.ELEMENT_NODE && (node as Element).tagName === 'H2') {
      if (currentTitle !== null) sections.push({ title: currentTitle, nodes: currentNodes });
      else before = [...currentNodes];
      currentTitle = (node as Element).textContent ?? '';
      currentNodes = [];
    } else {
      currentNodes.push(node);
    }
  });
  if (currentTitle !== null) sections.push({ title: currentTitle, nodes: currentNodes });

  prose.innerHTML = '';
  prose.classList.remove('prose');

  // Contenu avant le 1er h2
  if (before.filter(n => n.textContent?.trim()).length) {
    const intro = document.createElement('div');
    intro.className = 'prose';
    intro.style.marginBottom = '16px';
    before.forEach(n => intro.appendChild(n.cloneNode(true)));
    prose.appendChild(intro);
  }

  // Séparer les sections normales des Annexes
  const normalSections = sections.filter(s => !s.title.toLowerCase().includes('annex'));
  const annexeSection  = sections.find(s =>  s.title.toLowerCase().includes('annex'));

  // Accordéon pour les sections normales
  if (normalSections.length) {
    const acc = document.createElement('div');
    acc.className = 'accordion';

    normalSections.forEach((sec, i) => {
      const details = document.createElement('details');
      details.className = 'acc-item';
      if (i === 0) details.open = true;

      const summary = document.createElement('summary');
      summary.textContent = sec.title;
      summary.appendChild(chevron());
      details.appendChild(summary);

      const body = document.createElement('div');
      body.className = 'acc-body';
      sec.nodes.forEach(n => body.appendChild(n.cloneNode(true)));
      details.appendChild(body);
      acc.appendChild(details);
    });
    prose.appendChild(acc);
  }

  // Section Annexes avec style propre
  if (annexeSection) {
    const box = document.createElement('div');
    box.className = 'annexes';

    const title = document.createElement('h2');
    title.className = 'annexes-title';
    title.textContent = annexeSection.title;
    box.appendChild(title);

    const rule = document.createElement('hr');
    rule.className = 'annexes-rule';
    box.appendChild(rule);

    const linksWrap = document.createElement('div');
    linksWrap.className = 'annexes-links';

    // Ajouter les nœuds ; transformer les <a> pour avoir l'icône
    annexeSection.nodes.forEach(n => {
      const clone = n.cloneNode(true) as Element;
      if (clone.nodeType === Node.ELEMENT_NODE) {
        clone.querySelectorAll?.('a').forEach((a: Element) => {
          const anchor = a as HTMLAnchorElement;
          // Icône document devant chaque lien
          const iconSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
          anchor.innerHTML = iconSvg + anchor.textContent;
          anchor.target = '_blank';
          anchor.rel = 'noopener';
          linksWrap.appendChild(anchor);
          (clone as HTMLElement).style.display = 'none'; // masquer l'original si c'est dans un <p>/<li>
        });
        // Si c'est un <p> ou <li> sans lien restant, l'ajouter quand même
        const hasLinks = (clone as HTMLElement).querySelectorAll?.('a').length;
        if (!hasLinks) box.appendChild(clone);
      }
    });

    box.appendChild(linksWrap);
    prose.appendChild(box);
  }
})();
</script>
