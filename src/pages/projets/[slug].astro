---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;
---
<Base title={d.title} description={d.description_short}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-gray-700">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/catalogue" class="hover:text-gray-700">Catalogue</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700">{d.title}</span>
    </nav>

    <!-- Statut archivé -->
    {d.status === 'archivé' && (
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-800">
        Ce projet est archivé. L'enseignement a pu changer depuis sa publication.
      </div>
    )}

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Contenu principal -->
      <div class="md:col-span-2">
        <h1 class="text-3xl font-bold mb-4">{d.title}</h1>

        {d.description_short && (
          <p class="text-lg text-gray-600 mb-6">{d.description_short}</p>
        )}

        <!-- Vidéo YouTube -->
        {d.youtube && (
          <div class="aspect-video mb-8 rounded-xl overflow-hidden shadow">
            <iframe
              src={d.youtube}
              class="w-full h-full"
              allowfullscreen
              loading="lazy"
            />
          </div>
        )}

        <!-- Images -->
        {d.images && d.images.length > 0 && (
          <div class="grid grid-cols-2 gap-3 mb-8">
            {d.images.map((img: string) => (
              <img src={img} alt={d.title} class="rounded-lg w-full object-cover" loading="lazy" />
            ))}
          </div>
        )}

        <!-- Contenu Markdown -->
        <div class="prose prose-gray max-w-none">
          <Content />
        </div>
      </div>

      <!-- Métadonnées sidebar -->
      <aside class="space-y-6">
        <div class="bg-gray-50 rounded-xl p-5 text-sm space-y-3">
          {d.author && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Responsable</p>
              <p class="text-gray-900">{d.author}</p>
            </div>
          )}
          {d.members && d.members.length > 0 && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Équipe</p>
              <ul class="text-gray-700 space-y-0.5">
                {d.members.map((m: string) => <li>{m}</li>)}
              </ul>
            </div>
          )}
          {d.faculty && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Faculté</p>
              <p class="text-gray-900">{d.faculty}</p>
            </div>
          )}
          {d.course && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Cours</p>
              <p class="text-gray-900">{d.course} {d.course_code && `(${d.course_code})`}</p>
            </div>
          )}
          {d.level && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Niveau</p>
              <p class="text-gray-900">{d.level}</p>
            </div>
          )}
          {d.students && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Nombre d'étudiants</p>
              <p class="text-gray-900">{d.students}</p>
            </div>
          )}
          {d.year && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Mise en place</p>
              <p class="text-gray-900">{d.year}</p>
            </div>
          )}
          {d.category && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Axe pédagogique</p>
              <span class="inline-block bg-red-50 text-unige-red text-xs px-2 py-1 rounded-full font-medium">
                {d.category}
              </span>
            </div>
          )}
          {d.award && (
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Prix</p>
              <p class="text-gray-900">🏆 {d.award}</p>
            </div>
          )}
          {d.observation_accepted && (
            <div class="pt-2 border-t border-gray-200">
              <p class="text-xs text-green-700 font-medium">✓ Observation entre pairs acceptée</p>
            </div>
          )}
        </div>

        <a href="/catalogue" class="block text-center text-sm text-unige-red hover:underline">
          ← Retour au catalogue
        </a>
      </aside>
    </div>
  </div>
</Base>
