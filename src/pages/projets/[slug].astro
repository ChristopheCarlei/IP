---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

function getFacVar(fac?: string | null): string {
  if (!fac) return 'var(--rose)';
  const f = fac.toUpperCase();
  if (f.includes('FPSE') || f.includes('PSE') || f.includes('PSYCH')) return 'var(--fac-fapse)';
  if (f.includes('GSEM'))                                               return 'var(--fac-gsem)';
  if (f.includes('FTI')  || f.includes('TRAD'))                        return 'var(--fac-fti)';
  if (f.includes('SCIEN') && !f.includes('SOC'))                       return 'var(--fac-sciences)';
  if (f.includes('MED')  || f.includes('MÉD'))                         return 'var(--fac-medecine)';
  if (f.includes('DROIT')|| f.includes('LAW'))                         return 'var(--fac-droit)';
  if (f.includes('LETTR'))                                              return 'var(--fac-lettres)';
  if (f.includes('SOC')  || f.includes('SDS'))                         return 'var(--fac-sds)';
  if (f.includes('THEO') || f.includes('THÉO'))                        return 'var(--fac-theologie)';
  return 'var(--rose)';
}
function isLightFac(fac?: string | null): boolean {
  const f = fac?.toUpperCase() ?? '';
  return f.includes('SOC') || f.includes('SDS');
}

const facVar = getFacVar(d.faculty);
const light  = isLightFac(d.faculty);
---
<Base title={d.title} description={d.description_short}>
<style>
/* ---- Fiche projet ---------------------------------------- */

/* Fil d'Ariane */
.crumb-bar{background:var(--bg-soft);border-bottom:1px solid var(--line)}
.crumb{width:var(--content);margin:auto;padding:14px 0;font-size:13px;color:var(--faint);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.crumb a{text-decoration:none;color:inherit}
.crumb a:hover{color:var(--rose)}
.crumb .sep{opacity:.5}
.crumb .cur{color:var(--muted);font-weight:600}

/* ---- Bloc résumé (style fiche UNIGE) ---- */
.proj-card{width:var(--content);margin:clamp(24px,3vw,40px) auto;background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}

/* En-tête : badge faculté + titre */
.proj-card-head{padding:18px 24px 14px;border-bottom:1px solid var(--line)}
.fac-badge{display:inline-block;background:var(--fac,var(--rose));color:#fff;font-size:13px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;padding:5px 14px;border-radius:6px;margin-bottom:12px}
.fac-badge.light{color:var(--ink)}
.proj-card-head h1{font-size:clamp(22px,3vw,32px);font-weight:800;letter-spacing:-.02em;line-height:1.1;margin:0}

/* Tags (axe, prix, archivé) */
.tagrow{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:10px}
.tag{font-size:12px;font-weight:800;padding:4px 12px;border-radius:999px;white-space:nowrap}
.tag.axe{color:var(--rose-ink);background:var(--bg-rose)}
.tag.prix{color:#fff;display:inline-flex;align-items:center;gap:5px;background:var(--ink)}
.tag.archive{color:var(--ink);background:#FEF3C7;border:1px solid #FDE68A}

/* Corps : galerie gauche + description droite */
.proj-card-body{display:grid;grid-template-columns:1fr 1fr;gap:0;min-height:220px}
.proj-gallery{padding:20px 20px 16px;display:flex;flex-direction:column;gap:10px;border-right:1px solid var(--line)}
.gallery-imgs{display:grid;gap:8px}
.gallery-imgs.n1{grid-template-columns:1fr}
.gallery-imgs.n2{grid-template-columns:1fr 1fr}
.gallery-imgs.n3{grid-template-columns:1fr 1fr 1fr}
.gallery-imgs figure{margin:0}
.gallery-imgs img{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:var(--radius-sm);border:1px solid var(--line);display:block}
.gallery-imgs figcaption{font-size:11px;color:var(--faint);margin-top:4px;text-align:center;line-height:1.3}

/* Photo enseignant (si pas d'images de projet) */
.teacher-photo{width:100%;height:100%;object-fit:cover;object-position:center 15%;display:block;border-radius:0}

/* Côté description */
.proj-desc{padding:24px 28px;display:flex;flex-direction:column;gap:12px}
.proj-desc .desc-label{font-size:clamp(20px,2.2vw,26px);font-weight:800;color:var(--fac,var(--rose));line-height:1}
.proj-desc .desc-text{font-size:16px;line-height:1.65;color:var(--ink);font-style:italic;margin:0}
.proj-desc .desc-meta{margin-top:8px;display:flex;flex-direction:column;gap:8px;font-size:14.5px}
.proj-desc .desc-meta .row{display:flex;gap:6px;align-items:baseline}
.proj-desc .desc-meta strong{color:var(--ink);font-weight:700;white-space:nowrap}
.proj-desc .desc-meta a{color:var(--fac,var(--rose));font-weight:600;text-decoration:none}
.proj-desc .desc-meta a:hover{text-decoration:underline}
.proj-desc .desc-meta span{color:var(--muted)}

/* Barre infos en bas (couleur faculté) */
.proj-card-foot{background:var(--fac,var(--rose));display:flex;align-items:stretch}
.proj-card-foot.light .foot-item{color:var(--ink)}
.foot-item{flex:1;display:flex;align-items:center;gap:10px;padding:14px 20px;color:#fff;font-size:14px;font-weight:700}
.foot-item:not(:last-child){border-right:1px solid rgba(255,255,255,.2)}
.foot-item.light-sep:not(:last-child){border-right-color:rgba(0,0,0,.12)}
.foot-item svg{width:20px;height:20px;flex-shrink:0;opacity:.85}
.foot-item .fi-label{font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;opacity:.75;margin-bottom:2px}
.foot-item .fi-val{font-size:14px;font-weight:700;line-height:1.2}

/* ---- Corps principal (prose) ---- */
.body-wrap{width:var(--content);margin:0 auto clamp(48px,6vw,72px)}

/* ---- Accordéon ---- */
.accordion{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
details.acc-item{border-radius:var(--radius-sm);overflow:hidden}
details.acc-item summary{list-style:none;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 24px;background:#F2F2F2;cursor:pointer;font-size:18px;font-weight:400;color:var(--ink);letter-spacing:-.01em;user-select:none}
details.acc-item summary::-webkit-details-marker{display:none}
details.acc-item summary .acc-chevron{flex-shrink:0;transition:transform .22s ease;width:20px;height:20px;color:#555}
details.acc-item[open] summary .acc-chevron{transform:rotate(180deg)}
details.acc-item summary:hover{background:#EAEAEA}
.acc-body{padding:22px 28px 26px;border:1px solid var(--line);border-top:0;border-radius:0 0 var(--radius-sm) var(--radius-sm)}

/* Prose à l'intérieur de l'accordéon */
.acc-body h3{font-size:17px;font-weight:700;margin:20px 0 7px;color:var(--ink)}
.acc-body h3:first-child{margin-top:0}
.acc-body p{color:var(--muted);font-size:16px;line-height:1.7;margin:0 0 14px}
.acc-body p:last-child{margin-bottom:0}
.acc-body ul{margin:0 0 14px;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:9px}
.acc-body ul li{position:relative;padding-left:24px;color:var(--muted);font-size:16px;line-height:1.6}
.acc-body ul li::before{content:"";position:absolute;left:4px;top:10px;width:7px;height:7px;border-radius:2px;background:var(--fac,var(--rose))}
.acc-body blockquote{margin:18px 0;padding:4px 0 4px 18px;border-left:3px solid var(--fac,var(--rose));font-size:16px;line-height:1.6;color:var(--ink);font-style:italic}
.acc-body blockquote p{color:var(--ink);font-size:16px;font-style:italic;margin:0}
.acc-body a{color:var(--fac,var(--rose));font-weight:600;text-decoration:none}
.acc-body a:hover{text-decoration:underline}

/* Prose sans h2 (pas d'accordéon) */
.prose{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:clamp(24px,3vw,40px);box-shadow:var(--shadow)}
.prose h2{font-size:22px;font-weight:800;letter-spacing:-.01em;margin:32px 0 10px;line-height:1.2;color:var(--ink)}
.prose h2:first-child{margin-top:0}
.prose h3{font-size:17px;font-weight:700;margin:22px 0 7px;color:var(--ink)}
.prose p{color:var(--muted);font-size:16px;line-height:1.7;margin:0 0 14px}
.prose ul{margin:0 0 14px;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:9px}
.prose ul li{position:relative;padding-left:24px;color:var(--muted);font-size:16px;line-height:1.6}
.prose ul li::before{content:"";position:absolute;left:4px;top:10px;width:7px;height:7px;border-radius:2px;background:var(--fac,var(--rose))}
.prose blockquote{margin:22px 0;padding:4px 0 4px 20px;border-left:3px solid var(--fac,var(--rose));font-size:17px;line-height:1.55;color:var(--ink);font-style:italic}
.prose blockquote p{color:var(--ink);font-size:17px;font-style:italic;margin:0}

/* Vidéo embed */
.video-wrap{margin-bottom:24px}
.media{aspect-ratio:16/9;border-radius:var(--radius);overflow:hidden;background:var(--bg-soft);border:1px solid var(--line)}
.media iframe{width:100%;height:100%;border:0;display:block}

/* Observation encart */
.obs{margin-top:24px;border-radius:var(--radius);padding:18px 22px;background:color-mix(in srgb,var(--fac-sciences) 7%,#fff);border:1px solid color-mix(in srgb,var(--fac-sciences) 28%,#fff)}
.obs strong{display:flex;align-items:center;gap:9px;color:var(--fac-sciences);font-size:15px;font-weight:800;margin-bottom:5px}
.obs strong svg{width:18px;height:18px;flex-shrink:0}
.obs p{color:var(--muted);font-size:14px;margin:0}
.obs p a{color:var(--fac-sciences);font-weight:700}

/* Retour */
.back-link{display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:700;color:var(--muted);text-decoration:none;margin-bottom:20px}
.back-link:hover{color:var(--rose)}

@media(max-width:860px){
  .proj-card-body{grid-template-columns:1fr}
  .proj-gallery{border-right:0;border-bottom:1px solid var(--line)}
  .proj-card-foot{flex-wrap:wrap}
  .foot-item{flex:1 1 45%}
}
@media(max-width:560px){
  .gallery-imgs.n3{grid-template-columns:1fr 1fr}
  .foot-item{flex:1 1 100%}
}
</style>

<!-- Fil d'Ariane -->
<div class="crumb-bar">
  <nav class="crumb" aria-label="Fil d'Ariane">
    <a href="/">Accueil</a>
    <span class="sep">/</span>
    <a href="/catalogue">Catalogue</a>
    <span class="sep">/</span>
    <span class="cur">{d.title}</span>
  </nav>
</div>

<!-- Fiche résumé style UNIGE -->
<div style={`--fac:${facVar}`}>
<div class="proj-card">

  <!-- En-tête -->
  <div class="proj-card-head">
    {d.faculty && (
      <div class={`fac-badge${light ? ' light' : ''}`}>{d.faculty}</div>
    )}
    <h1>{d.title}</h1>
    <div class="tagrow">
      {d.category && <span class="tag axe">{d.category}</span>}
      {d.award && (
        <span class="tag prix">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
            <path d="M12 2l2.4 5 5.6.6-4.2 3.8 1.2 5.6L12 19.8 6.9 17 8 11.4 3.8 7.6l5.6-.6z"/>
          </svg>
          {d.award}
        </span>
      )}
      {d.status === 'archivé' && <span class="tag archive">Archivé</span>}
    </div>
  </div>

  <!-- Corps : galerie + description -->
  <div class="proj-card-body">

    <!-- Galerie images ou photo enseignant -->
    <div class="proj-gallery">
      {(d.images && d.images.length > 0) ? (
        <div class={`gallery-imgs n${Math.min(d.images.length, 3)}`}>
          {d.images.slice(0, 3).map((img: string) => (
            <figure>
              <img src={img} alt={d.title} loading="lazy" />
            </figure>
          ))}
        </div>
      ) : d.photo ? (
        <img src={d.photo} alt={d.author ?? d.title} class="teacher-photo" style="border-radius:var(--radius-sm);max-height:280px;object-fit:cover" />
      ) : (
        <div style={`background:var(--fac,var(--rose));border-radius:var(--radius-sm);flex:1;min-height:180px;display:flex;align-items:center;justify-content:center`}>
          <span style="font-size:56px;font-weight:800;color:rgba(255,255,255,.25)">
            {(d.author ?? d.title ?? '').split(' ').slice(0,2).map((w: string) => w[0] ?? '').join('').toUpperCase()}
          </span>
        </div>
      )}
    </div>

    <!-- Description -->
    <div class="proj-desc">
      <div class="desc-label">Projet</div>
      {d.description_short && (
        <p class="desc-text">{d.description_short}</p>
      )}
      <div class="desc-meta">
        {d.course && (
          <div class="row">
            <strong>Cours :</strong>
            <span>
              <a href="#">{d.course}</a>
              {d.level ? ` / ${d.level}` : ''}
            </span>
          </div>
        )}
        {d.contact && (
          <div class="row">
            <strong>Contact :</strong>
            <a href={`mailto:${d.contact}`}>{d.contact}</a>
          </div>
        )}
        {d.author && !d.course && !d.contact && (
          <div class="row">
            <strong>Responsable :</strong>
            <span>{d.author}</span>
          </div>
        )}
        {d.year && (
          <div class="row">
            <strong>Depuis :</strong>
            <span>{d.year}</span>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Barre infos colorée -->
  <div class={`proj-card-foot${light ? ' light' : ''}`}>
    {d.category && (
      <div class="foot-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
        </svg>
        <div>
          <div class="fi-label">Axe</div>
          <div class="fi-val">{d.category}</div>
        </div>
      </div>
    )}
    {d.innovation_type && (
      <div class="foot-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a7 7 0 0 1 7 7c0 3-1.8 5.4-4.5 6.5V17a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1v-1.5C6.8 14.4 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M9 21h6"/>
        </svg>
        <div>
          <div class="fi-label">Type d'innovation</div>
          <div class="fi-val">{d.innovation_type}</div>
        </div>
      </div>
    )}
    {d.students && (
      <div class="foot-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <div>
          <div class="fi-label">Étudiant·es</div>
          <div class="fi-val">{d.students}</div>
        </div>
      </div>
    )}
  </div>

</div>
</div>

<!-- Corps étendu (contenu Markdown) -->
<div class="body-wrap" style={`--fac:${facVar}`}>
  <a class="back-link" href="/catalogue">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 19l-7-7 7-7"/>
    </svg>
    Retour au catalogue
  </a>

  {d.youtube && (
    <div class="video-wrap">
      <div class="media">
        <iframe src={d.youtube} allowfullscreen loading="lazy" title={`Vidéo — ${d.title}`} />
      </div>
    </div>
  )}

  <!-- Le contenu markdown est rendu ici ; le script ci-dessous le transforme en accordéon -->
  <div class="prose" id="proj-prose">
    <Content />
  </div>

  {d.observation_accepted && (
    <div class="obs">
      <strong>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2.5 12C4 7.9 7.7 5 12 5s8 2.9 9.5 7c-1.5 4.1-5.2 7-9.5 7s-8-2.9-9.5-7z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        Observation entre pairs
      </strong>
      <p>
        Cet·te enseignant·e accepte que des collègues observent son cours.
        <a href="/observation">En savoir plus →</a>
      </p>
    </div>
  )}
</div>
<script>
/* Transforme les h2 du bloc #proj-prose en accordéon <details> */
(function () {
  const prose = document.getElementById('proj-prose');
  if (!prose) return;

  const children = Array.from(prose.childNodes);
  const h2s = prose.querySelectorAll('h2');
  if (!h2s.length) return; // pas de sections → prose normale

  /* Chevron SVG réutilisable */
  function chevron() {
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '1.8');
    svg.setAttribute('stroke-linecap', 'round');
    svg.setAttribute('stroke-linejoin', 'round');
    svg.classList.add('acc-chevron');
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', 'M6 9l6 6 6-6');
    svg.appendChild(path);
    return svg;
  }

  /* Construire les sections */
  const sections: { heading: Element; nodes: Node[] }[] = [];
  let before: Node[] = [];   // nœuds avant le 1er h2 (intro, etc.)
  let currentH2: Element | null = null;
  let currentNodes: Node[] = [];

  children.forEach(node => {
    if (node.nodeType === Node.ELEMENT_NODE && (node as Element).tagName === 'H2') {
      if (currentH2) sections.push({ heading: currentH2, nodes: currentNodes });
      else before = [...currentNodes];
      currentH2 = node as Element;
      currentNodes = [];
    } else {
      currentNodes.push(node);
    }
  });
  if (currentH2) sections.push({ heading: currentH2, nodes: currentNodes });

  /* Vider le prose */
  prose.innerHTML = '';
  prose.classList.remove('prose');

  /* Réinsérer le contenu avant le 1er h2 */
  if (before.length) {
    const intro = document.createElement('div');
    intro.className = 'prose';
    intro.style.marginBottom = '16px';
    before.forEach(n => intro.appendChild(n.cloneNode(true)));
    prose.appendChild(intro);
  }

  /* Créer l'accordéon */
  const acc = document.createElement('div');
  acc.className = 'accordion';

  sections.forEach((sec, i) => {
    const details = document.createElement('details');
    details.className = 'acc-item';
    if (i === 0) details.open = true; // première section ouverte

    const summary = document.createElement('summary');
    summary.textContent = sec.heading.textContent ?? '';
    summary.appendChild(chevron());
    details.appendChild(summary);

    const body = document.createElement('div');
    body.className = 'acc-body';
    sec.nodes.forEach(n => body.appendChild(n.cloneNode(true)));
    details.appendChild(body);

    acc.appendChild(details);
  });

  prose.appendChild(acc);
})();
</script>
</Base>
