---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

// Couleurs par faculté
const facultyColors: Record<string, string> = {
  FPSE:      '#4B0B71',
  GSEM:      '#465F7F',
  FTI:       '#FF5C00',
  Sciences:  '#007E64',
  Médecine:  '#96004B',
  Droit:     '#0067C5',
  Lettres:   '#F1AB00',
  SdS:       '#00b1ae',
  Théologie: '#CF0063',
};
function facultyColor(fac?: string): string {
  if (!fac) return '#6B7280';
  for (const [key, val] of Object.entries(facultyColors)) {
    if (fac.toUpperCase().includes(key.toUpperCase())) return val;
  }
  return '#6B7280';
}
const fc = facultyColor(d.faculty);
---
<Base title={d.title} description={d.description_short}>

  <!-- Bande couleur faculté -->
  <div class="h-1.5 w-full" style={`background-color: ${fc}`} />

  <!-- En-tête projet -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 py-6">

      <!-- Breadcrumb -->
      <nav class="text-xs text-gray-400 mb-4 flex items-center gap-1.5" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-gray-700 transition">Accueil</a>
        <span>/</span>
        <a href="/catalogue" class="hover:text-gray-700 transition">Catalogue</a>
        <span>/</span>
        <span class="text-gray-600 truncate max-w-xs">{d.title}</span>
      </nav>

      <!-- Tags faculté + statut -->
      <div class="flex items-center gap-2 flex-wrap mb-3">
        {d.faculty && (
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full text-white" style={`background-color: ${fc}`}>
            {d.faculty}
          </span>
        )}
        {d.category && (
          <span class="text-xs font-medium text-gray-500 border border-gray-200 px-2.5 py-1 rounded-full">
            {d.category}
          </span>
        )}
        {d.status === 'archivé' && (
          <span class="text-xs bg-amber-100 text-amber-700 font-medium px-2.5 py-1 rounded-full">
            Archivé
          </span>
        )}
        {d.award && (
          <span class="text-xs bg-yellow-50 text-yellow-700 font-medium px-2.5 py-1 rounded-full border border-yellow-200">
            🏆 {d.award}
          </span>
        )}
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight">{d.title}</h1>
      {d.author && <p class="text-gray-500 mt-1.5">{d.author}</p>}
    </div>
  </div>

  <!-- Corps -->
  <div class="max-w-7xl mx-auto px-4 py-8">

    {d.status === 'archivé' && (
      <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r p-4 mb-8 text-sm text-amber-800">
        <strong class="font-semibold">Projet archivé.</strong> L'enseignement a pu évoluer depuis la publication de cette fiche.
      </div>
    )}

    <div class="grid md:grid-cols-3 gap-10">

      <!-- Colonne principale -->
      <div class="md:col-span-2">

        {d.description_short && (
          <p class="text-lg text-gray-600 leading-relaxed mb-8 pb-8 border-b border-gray-100">
            {d.description_short}
          </p>
        )}

        <!-- Vidéo YouTube -->
        {d.youtube && (
          <div class="aspect-video mb-8 rounded-lg overflow-hidden shadow-md bg-black">
            <iframe
              src={d.youtube}
              class="w-full h-full"
              allowfullscreen
              loading="lazy"
              title={`Vidéo — ${d.title}`}
            />
          </div>
        )}

        <!-- Images -->
        {d.images && d.images.length > 0 && (
          <div class={`grid gap-3 mb-8 ${d.images.length === 1 ? '' : 'grid-cols-2'}`}>
            {d.images.map((img: string) => (
              <img src={img} alt={d.title} class="rounded-lg w-full object-cover shadow-sm" loading="lazy" />
            ))}
          </div>
        )}

        <!-- Contenu Markdown -->
        <div class="prose prose-gray prose-headings:text-gray-900 prose-h2:text-xl prose-h2:font-bold prose-h2:mt-8 prose-h2:mb-3 prose-p:leading-relaxed prose-blockquote:border-l-unige-red prose-blockquote:text-gray-600 max-w-none">
          <Content />
        </div>

        <!-- Lien observation -->
        {d.observation_accepted && (
          <div class="mt-10 p-5 bg-green-50 border border-green-200 rounded-lg">
            <p class="text-sm font-semibold text-green-800 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Observation entre pairs acceptée
            </p>
            <p class="text-sm text-green-700 mt-1">
              Cet·te enseignant·e accepte que des collègues observent son cours.
              <a href="/observation" class="underline ml-1 font-medium">En savoir plus →</a>
            </p>
          </div>
        )}
      </div>

      <!-- Sidebar métadonnées -->
      <aside>
        <div class="bg-gray-50 border border-gray-200 rounded-lg overflow-hidden sticky top-28">
          <!-- En-tête sidebar couleur faculté -->
          <div class="px-5 py-3 text-white text-sm font-semibold" style={`background-color: ${fc}`}>
            Fiche du projet
          </div>

          <dl class="px-5 py-4 space-y-4 text-sm">
            {d.author && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Responsable</dt>
                <dd class="text-gray-900">{d.author}</dd>
                {d.contact && (
                  <dd class="mt-0.5">
                    <a href={`mailto:${d.contact}`} class="text-xs text-unige-red hover:underline">{d.contact}</a>
                  </dd>
                )}
              </div>
            )}

            {d.faculty && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Faculté</dt>
                <dd>
                  <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full text-white" style={`background-color: ${fc}`}>
                    {d.faculty}
                  </span>
                </dd>
              </div>
            )}

            {d.course && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Cours</dt>
                <dd class="text-gray-900">{d.course}</dd>
                {d.course_code && <dd class="text-xs text-gray-500 mt-0.5">Code : {d.course_code}</dd>}
              </div>
            )}

            {d.level && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Niveau</dt>
                <dd class="text-gray-900">{d.level}</dd>
              </div>
            )}

            {d.students && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Nb d'étudiants</dt>
                <dd class="text-gray-900">{d.students}</dd>
              </div>
            )}

            {d.year && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Mise en place</dt>
                <dd class="text-gray-900">{d.year}</dd>
              </div>
            )}

            {d.category && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Axe pédagogique</dt>
                <dd>
                  <span class="inline-block bg-red-50 text-unige-red text-xs px-2.5 py-1 rounded-full font-medium border border-red-100">
                    {d.category}
                  </span>
                </dd>
              </div>
            )}

            {d.innovation_type && (
              <div>
                <dt class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Type d'innovation</dt>
                <dd class="text-gray-700 text-xs leading-relaxed">{d.innovation_type}</dd>
              </div>
            )}
          </dl>

          <!-- Actions -->
          <div class="px-5 py-4 border-t border-gray-200 space-y-2">
            <a href="/catalogue" class="flex items-center gap-1.5 text-sm text-gray-600 hover:text-unige-red transition">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
              Retour au catalogue
            </a>
          </div>
        </div>
      </aside>

    </div>
  </div>

</Base>
