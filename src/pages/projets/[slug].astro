---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

function getFacVar(fac?: string | null): string {
  if (!fac) return 'var(--rose)';
  const f = fac.toUpperCase();
  if (f.includes('FPSE') || f.includes('PSE') || f.includes('PSYCH')) return 'var(--fac-fapse)';
  if (f.includes('GSEM'))                                               return 'var(--fac-gsem)';
  if (f.includes('FTI')  || f.includes('TRAD'))                        return 'var(--fac-fti)';
  if (f.includes('SCIEN') && !f.includes('SOC'))                       return 'var(--fac-sciences)';
  if (f.includes('MED')  || f.includes('MÉD'))                         return 'var(--fac-medecine)';
  if (f.includes('DROIT')|| f.includes('LAW'))                         return 'var(--fac-droit)';
  if (f.includes('LETTR'))                                              return 'var(--fac-lettres)';
  if (f.includes('SOC')  || f.includes('SDS'))                         return 'var(--fac-sds)';
  if (f.includes('THEO') || f.includes('THÉO'))                        return 'var(--fac-theologie)';
  return 'var(--rose)';
}

const facVar = getFacVar(d.faculty);
---
<Base title={d.title} description={d.description_short}>
<style>
/* ---- Fiche projet ---------------------------------------- */
.fac-band{height:6px;width:100%}
.proj-head{background:#fff;border-bottom:1px solid var(--line)}
.proj-head-inner{width:var(--content);margin:auto;padding:24px 0 30px}
.crumb{font-size:13px;color:var(--faint);display:flex;align-items:center;gap:8px;margin-bottom:20px;flex-wrap:wrap}
.crumb a{text-decoration:none;color:inherit}
.crumb a:hover{color:var(--rose)}
.crumb .sep{opacity:.6}
.crumb .cur{color:var(--muted);font-weight:600}
.tagrow{display:flex;align-items:center;gap:9px;flex-wrap:wrap;margin-bottom:16px}
.tag{font-size:12.5px;font-weight:800;padding:5px 13px;border-radius:999px;white-space:nowrap}
.tag.fac{color:#fff}
.tag.axe{color:var(--rose-ink);background:var(--bg-rose)}
.tag.prix{color:#fff;display:inline-flex;align-items:center;gap:6px;background:var(--ink)}
.tag.archive{color:var(--ink);background:#FEF3C7;border:1px solid #FDE68A}
.proj-head h1{font-size:clamp(30px,4.2vw,50px);line-height:1.04;letter-spacing:-.025em;font-weight:800;max-width:20ch;margin:0}
.proj-head .author{color:var(--muted);font-size:18px;margin-top:12px;font-weight:600}

.body-wrap{width:var(--content);margin:auto;padding:clamp(36px,5vw,56px) 0;display:grid;grid-template-columns:1fr 340px;gap:clamp(32px,4vw,56px);align-items:start}
.lead-text{font-size:21px;line-height:1.5;color:var(--ink);font-weight:400;margin:0 0 32px;padding-bottom:32px;border-bottom:1px solid var(--line)}
.media{aspect-ratio:16/9;border-radius:var(--radius);overflow:hidden;background:var(--bg-soft);border:1px solid var(--line);margin-bottom:36px;position:relative}
.media iframe{width:100%;height:100%;border:0;display:block}
.media-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px}
.media-placeholder .play{width:64px;height:64px;border-radius:50%;background:var(--fac,var(--rose));display:grid;place-items:center;color:#fff}
.media-placeholder .play svg{width:26px;height:26px;margin-left:3px}

/* Prose (contenu markdown) */
.prose h2{font-size:24px;font-weight:800;letter-spacing:-.01em;margin:36px 0 12px;line-height:1.2}
.prose h2:first-child{margin-top:0}
.prose h3{font-size:18px;font-weight:700;margin:24px 0 8px}
.prose p{color:var(--muted);font-size:16.5px;line-height:1.7;margin:0 0 16px}
.prose ul{margin:0 0 16px;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:10px}
.prose ul li{position:relative;padding-left:26px;color:var(--muted);font-size:16.5px;line-height:1.6}
.prose ul li::before{content:"";position:absolute;left:4px;top:11px;width:7px;height:7px;border-radius:2px;background:var(--fac,var(--rose))}
.prose blockquote{margin:24px 0;padding:4px 0 4px 22px;border-left:3px solid var(--fac,var(--rose));font-size:18px;line-height:1.55;color:var(--ink);font-style:italic}
.prose blockquote p{color:var(--ink);font-size:18px;font-style:italic}

/* Sidebar */
.sidebar{position:sticky;top:96px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
.sidebar .sb-head{padding:14px 20px;font-size:14px;font-weight:800;letter-spacing:.02em;color:#fff}
.sidebar dl{margin:0;padding:8px 20px 4px}
.sidebar dt{font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--faint);margin:16px 0 3px}
.sidebar dd{margin:0;font-size:15px;color:var(--ink);font-weight:600}
.sidebar dd.sub{font-size:13px;color:var(--muted);font-weight:400;margin-top:2px}
.sidebar dd a{color:var(--rose);font-weight:700;font-size:14px;text-decoration:none}
.sidebar dd a:hover{text-decoration:underline}
.sidebar .sb-foot{border-top:1px solid var(--line);padding:16px 20px;margin-top:14px}
.sidebar .sb-foot a{display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:700;color:var(--muted);text-decoration:none}
.sidebar .sb-foot a:hover{color:var(--rose)}

/* Encart observation */
.obs{margin-top:12px;border-radius:var(--radius);padding:20px 22px;background:color-mix(in srgb,var(--fac-sciences) 7%,#fff);border:1px solid color-mix(in srgb,var(--fac-sciences) 28%,#fff)}
.obs strong{display:flex;align-items:center;gap:9px;color:var(--fac-sciences);font-size:15px;font-weight:800;margin-bottom:6px}
.obs strong svg{width:18px;height:18px;flex-shrink:0}
.obs p{color:var(--muted);font-size:14.5px;margin:0}
.obs p a{color:var(--fac-sciences);font-weight:700}

/* Images */
.images-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:36px}
.images-grid.single{grid-template-columns:1fr}
.images-grid img{border-radius:var(--radius-sm);width:100%;object-fit:cover;border:1px solid var(--line)}

@media(max-width:880px){
  .body-wrap{grid-template-columns:1fr}
  .sidebar{position:static;order:-1}
}
</style>

<!-- Bande couleur faculté -->
<div class="fac-band" style={`background:${facVar}`}></div>

<!-- En-tête projet -->
<div class="proj-head">
  <div class="proj-head-inner">
    <nav class="crumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a>
      <span class="sep">/</span>
      <a href="/catalogue">Catalogue</a>
      <span class="sep">/</span>
      <span class="cur">{d.title}</span>
    </nav>

    <div class="tagrow">
      {d.faculty && (
        <span class="tag fac" style={`background:${facVar}`}>{d.faculty}</span>
      )}
      {d.category && (
        <span class="tag axe">{d.category}</span>
      )}
      {d.award && (
        <span class="tag prix">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor">
            <path d="M12 2l2.4 5 5.6.6-4.2 3.8 1.2 5.6L12 19.8 6.9 17 8 11.4 3.8 7.6l5.6-.6z"/>
          </svg>
          {d.award}
        </span>
      )}
      {d.status === 'archivé' && (
        <span class="tag archive">Archivé</span>
      )}
    </div>

    <h1>{d.title}</h1>
    {d.author && (
      <div style="display:flex;align-items:center;gap:14px;margin-top:14px">
        {d.photo && (
          <img src={d.photo} alt={d.author} class="avatar-lg" />
        )}
        <p class="author" style="margin:0">
          {d.author}{d.faculty ? ` · ${d.faculty}` : ''}
        </p>
      </div>
    )}
  </div>
</div>

<!-- Corps : grille main + sidebar -->
<div class="body-wrap" style={`--fac:${facVar}`}>

  <!-- Colonne principale -->
  <div>
    {d.description_short && (
      <p class="lead-text">{d.description_short}</p>
    )}

    {d.youtube && (
      <div class="media">
        <iframe
          src={d.youtube}
          allowfullscreen
          loading="lazy"
          title={`Vidéo — ${d.title}`}
        />
      </div>
    )}

    {d.images && d.images.length > 0 && (
      <div class={`images-grid${d.images.length === 1 ? ' single' : ''}`}>
        {d.images.map((img: string) => (
          <img src={img} alt={d.title} loading="lazy" />
        ))}
      </div>
    )}

    <div class="prose">
      <Content />
    </div>
  </div>

  <!-- Sidebar -->
  <aside>
    <div class="sidebar">
      <div class="sb-head" style={`background:${facVar}`}>Fiche du projet</div>
      <dl>
        {d.author && (
          <>
            <dt>Responsable</dt>
            <dd style="display:flex;align-items:center;gap:10px">
              {d.photo && (
                <img src={d.photo} alt={d.author} class="avatar" />
              )}
              <span>{d.author}</span>
            </dd>
            {d.contact && (
              <dd class="sub"><a href={`mailto:${d.contact}`}>{d.contact}</a></dd>
            )}
          </>
        )}

        {d.faculty && (
          <>
            <dt>Faculté</dt>
            <dd>{d.faculty}</dd>
          </>
        )}

        {d.course && (
          <>
            <dt>Cours</dt>
            <dd>{d.course}</dd>
            {d.course_code && <dd class="sub">Code : {d.course_code}</dd>}
          </>
        )}

        {d.level && (
          <>
            <dt>Niveau</dt>
            <dd>{d.level}</dd>
          </>
        )}

        {d.students && (
          <>
            <dt>Étudiant·es</dt>
            <dd>{d.students}</dd>
          </>
        )}

        {d.year && (
          <>
            <dt>Mise en place</dt>
            <dd>Depuis {d.year}</dd>
          </>
        )}

        {d.category && (
          <>
            <dt>Axe pédagogique</dt>
            <dd>{d.category}</dd>
          </>
        )}

        {d.innovation_type && (
          <>
            <dt>Type d'innovation</dt>
            <dd class="sub">{d.innovation_type}</dd>
          </>
        )}
      </dl>
      <div class="sb-foot">
        <a href="/catalogue">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
               stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 19l-7-7 7-7"/>
          </svg>
          Retour au catalogue
        </a>
      </div>
    </div>

    {d.observation_accepted && (
      <div class="obs">
        <strong>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.5 12C4 7.9 7.7 5 12 5s8 2.9 9.5 7c-1.5 4.1-5.2 7-9.5 7s-8-2.9-9.5-7z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          Observation entre pairs
        </strong>
        <p>
          Cet·te enseignant·e accepte que des collègues observent son cours.
          <a href="/observation">En savoir plus →</a>
        </p>
      </div>
    )}
  </aside>

</div>
</Base>
