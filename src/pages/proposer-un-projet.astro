---
import Base from '../layouts/Base.astro';
import { innovations } from '../innovations';

const facultes = ['Sciences', 'Médecine', 'Lettres', 'SDS', 'GSEM', 'Droit', 'Théologie', 'FPSE', 'FTI', 'SEA', 'DISTIC', 'Rectorat', 'Autre'];
const niveaux = ['Bachelor', 'Master', 'Doctorat', 'Formation continue', 'Tous'];
const effectifs = ['Moins de 25', '25-75', '75-150', 'Plus de 150'];
const categories = ['Préparer', 'Rendre actif', 'Responsabiliser', 'Faire créer'];

// Types d'innovation proposés dynamiquement selon la catégorie pédagogique choisie (cf. src/innovations.ts)
const innovationsByCategory: Record<string, { value: string; label: string }[]> = {};
for (const cat of categories) {
  innovationsByCategory[cat] = innovations.filter(i => i.axisFr === cat).map(i => ({ value: i.typeFr, label: i.fr }));
}
---
<Base title="Proposer un projet" description="Proposez votre projet d'innovation pédagogique pour publication sur la plateforme Innovations Pédagogiques de l'Université de Genève.">
<style>
.pp-hero{background:#fff;border-bottom:1px solid var(--line)}
.pp-hero-inner{width:var(--content);margin:auto;padding:clamp(40px,5vw,64px) 0}
.pp-hero-eyebrow{display:inline-block;font-size:12px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--rose);margin-bottom:16px}
.pp-hero h1{font-size:clamp(36px,4.6vw,56px);line-height:1;font-weight:800;letter-spacing:-.03em;color:var(--ink);margin:0}
.pp-hero p{color:var(--muted);font-size:16.5px;line-height:1.7;max-width:72ch;margin:18px 0 0}
.pp-note{display:flex;gap:12px;align-items:flex-start;background:var(--bg-rose);border-radius:var(--radius-sm);padding:16px 18px;margin-top:24px;max-width:72ch}
.pp-note svg{width:20px;height:20px;flex-shrink:0;color:var(--rose-deep);margin-top:1px}
.pp-note p{margin:0;color:var(--rose-ink);font-size:14px;line-height:1.6}

.pp-wrap{width:var(--content);margin:auto;padding:clamp(36px,5vw,64px) 0}
form{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:clamp(24px,4vw,40px);max-width:900px}

.pp-sec{margin-bottom:32px}
.pp-sec:last-of-type{margin-bottom:0}
.pp-sec h2{font-size:13px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--rose);margin:0 0 18px;padding-bottom:10px;border-bottom:1px solid var(--line)}

.pp-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.pp-field{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
.pp-field.full{grid-column:1 / -1}
.pp-field label{font-size:13.5px;font-weight:700;color:var(--ink)}
.pp-field label .opt{font-weight:400;color:var(--faint);text-transform:none;letter-spacing:0}
.pp-field input[type="text"],
.pp-field input[type="email"],
.pp-field input[type="number"],
.pp-field input[type="url"],
.pp-field select,
.pp-field textarea{
  font-family:var(--font);font-size:15px;color:var(--ink);
  border:1.5px solid var(--line-strong);border-radius:var(--radius-sm);
  padding:10px 13px;background:#fff;width:100%;
}
.pp-field input:focus,.pp-field select:focus,.pp-field textarea:focus{
  outline:2px solid var(--rose);outline-offset:1px;border-color:var(--rose);
}
.pp-field textarea{resize:vertical;min-height:90px;line-height:1.5}
.pp-field input[type="file"]{font-size:14px;color:var(--muted)}
.pp-hint{font-size:12.5px;color:var(--faint)}

.pp-check{display:flex;align-items:flex-start;gap:10px;grid-column:1/-1}
.pp-check input{margin-top:3px;width:16px;height:16px;accent-color:var(--rose)}
.pp-check label{font-size:14px;font-weight:600;color:var(--ink)}

.pp-hp{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden}

.pp-submit{display:flex;align-items:center;gap:16px;margin-top:8px;flex-wrap:wrap}
.pp-submit .btn{padding:13px 28px;font-size:15.5px}
.pp-submit .req{font-size:13px;color:var(--faint)}

@media(max-width:680px){.pp-grid{grid-template-columns:1fr}}
</style>

<div class="pp-hero">
  <div class="pp-hero-inner">
    <span class="pp-hero-eyebrow">Innovations Pédagogiques · UNIGE</span>
    <h1>Proposer un projet</h1>
    <p>
      Vous mettez en place une pratique pédagogique innovante dans votre enseignement ? Décrivez-la
      ci-dessous pour qu'elle soit recensée sur la plateforme.
    </p>
    <div class="pp-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      <p>
        Votre proposition est relue par l'équipe de la plateforme avant publication — elle n'apparaît
        pas automatiquement sur le site. Nous pourrons vous recontacter pour préciser certains points.
      </p>
    </div>
  </div>
</div>

<div class="pp-wrap">
  <form name="proposition-projet" method="POST" data-netlify="true" netlify-honeypot="bot-field" enctype="multipart/form-data" action="/merci-projet">
    <input type="hidden" name="form-name" value="proposition-projet" />
    <p class="pp-hp"><label>Ne pas remplir si humain·e : <input name="bot-field" /></label></p>

    <div class="pp-sec">
      <h2>Vos coordonnées</h2>
      <div class="pp-grid">
        <div class="pp-field full">
          <label for="photo">Votre photo <span class="opt">portrait, idéalement carré — sera publiée à côté du projet</span></label>
          <input type="file" id="photo" name="photo" accept="image/*" />
        </div>
        <div class="pp-field">
          <label for="submitter_name">Votre nom et prénom *</label>
          <input type="text" id="submitter_name" name="submitter_name" required />
        </div>
        <div class="pp-field">
          <label for="submitter_email">Votre e-mail *</label>
          <input type="email" id="submitter_email" name="submitter_email" required />
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>Le projet</h2>
      <div class="pp-grid">
        <div class="pp-field">
          <label for="title">Titre du projet (FR) *</label>
          <input type="text" id="title" name="title" required />
        </div>
        <div class="pp-field">
          <label for="title_en">Titre du projet (EN) <span class="opt">optionnel</span></label>
          <input type="text" id="title_en" name="title_en" />
        </div>
        <div class="pp-field">
          <label for="author">Responsable du projet *</label>
          <input type="text" id="author" name="author" required />
        </div>
        <div class="pp-field">
          <label for="author_email">E-mail du/de la responsable <span class="opt">si différent</span></label>
          <input type="email" id="author_email" name="author_email" />
        </div>
        <div class="pp-field full">
          <label for="members">Autres membres de l'équipe <span class="opt">optionnel, un par ligne</span></label>
          <textarea id="members" name="members"></textarea>
        </div>
        <div class="pp-field">
          <label for="faculty">Faculté / service *</label>
          <select id="faculty" name="faculty" required>
            <option value="" disabled selected>Choisir…</option>
            {facultes.map(f => <option value={f}>{f}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="course">Cours concerné</label>
          <input type="text" id="course" name="course" />
        </div>
        <div class="pp-field">
          <label for="course_code">Code du cours <span class="opt">optionnel</span></label>
          <input type="text" id="course_code" name="course_code" />
        </div>
        <div class="pp-field">
          <label for="year">Année de mise en place</label>
          <input type="text" id="year" name="year" placeholder="ex. 2025" />
        </div>
        <div class="pp-field">
          <label for="level">Niveau d'études</label>
          <select id="level" name="level">
            <option value="" disabled selected>Choisir…</option>
            {niveaux.map(n => <option value={n}>{n}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="students">Nombre d'étudiant·es concerné·es</label>
          <select id="students" name="students">
            <option value="" disabled selected>Choisir…</option>
            {effectifs.map(e => <option value={e}>{e}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="category">Catégorie pédagogique</label>
          <select id="category" name="category">
            <option value="" disabled selected>Choisir…</option>
            {categories.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="innovation_type">Type d'innovation <span class="opt">choisissez d'abord la catégorie</span></label>
          <select id="innovation_type" name="innovation_type" disabled>
            <option value="" selected>Choisir d'abord une catégorie…</option>
          </select>
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>Description</h2>
      <div class="pp-grid">
        <div class="pp-field full">
          <label for="description_short">Description courte (FR) * <span class="opt">2-3 phrases</span></label>
          <textarea id="description_short" name="description_short" required></textarea>
        </div>
        <div class="pp-field full">
          <label for="description_short_en">Description courte (EN) <span class="opt">optionnel</span></label>
          <textarea id="description_short_en" name="description_short_en"></textarea>
        </div>
        <div class="pp-field full">
          <label for="situation_depart">Situation de départ <span class="opt">contexte, problème rencontré avant la mise en place</span></label>
          <textarea id="situation_depart" name="situation_depart" style="min-height:120px"></textarea>
        </div>
        <div class="pp-field full">
          <label for="mise_en_place">Mise en place et déroulement <span class="opt">comment le dispositif fonctionne concrètement</span></label>
          <textarea id="mise_en_place" name="mise_en_place" style="min-height:120px"></textarea>
        </div>
        <div class="pp-field full">
          <label for="avis_etudiants">Avis des étudiant·es <span class="opt">retours, citations, ressenti recueillis</span></label>
          <textarea id="avis_etudiants" name="avis_etudiants" style="min-height:100px"></textarea>
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>Médias &amp; distinctions</h2>
      <div class="pp-grid">
        <div class="pp-field">
          <label for="youtube">Lien vidéo YouTube <span class="opt">optionnel</span></label>
          <input type="url" id="youtube" name="youtube" placeholder="https://youtube.com/embed/…" />
        </div>
        <div class="pp-field">
          <label for="images">Photos du projet <span class="opt">optionnel, plusieurs fichiers possibles</span></label>
          <input type="file" id="images" name="images" accept="image/*" multiple />
        </div>
        <div class="pp-field">
          <label for="award">Prix obtenu <span class="opt">optionnel</span></label>
          <input type="text" id="award" name="award" />
        </div>
        <div class="pp-field">
          <label for="award_year">Année du prix <span class="opt">optionnel</span></label>
          <input type="text" id="award_year" name="award_year" />
        </div>
        <div class="pp-check">
          <input type="checkbox" id="observation_accepted" name="observation_accepted" value="oui" />
          <label for="observation_accepted">J'accepte que des collègues observent une séance de ce cours</label>
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>Message complémentaire</h2>
      <div class="pp-field full">
        <label for="message">Autre chose à préciser ? <span class="opt">optionnel</span></label>
        <textarea id="message" name="message"></textarea>
      </div>
    </div>

    <div class="pp-submit">
      <button type="submit" class="btn primary">Envoyer ma proposition</button>
      <span class="req">* champs obligatoires</span>
    </div>
  </form>
</div>

<script define:vars={{ innovationsByCategory }}>
  const categorySelect = document.getElementById('category');
  const typeSelect = document.getElementById('innovation_type');

  categorySelect.addEventListener('change', () => {
    const types = innovationsByCategory[categorySelect.value] || [];
    typeSelect.innerHTML = '';

    if (!types.length) {
      typeSelect.disabled = true;
      const opt = document.createElement('option');
      opt.value = '';
      opt.textContent = "Choisir d'abord une catégorie…";
      typeSelect.appendChild(opt);
      return;
    }

    typeSelect.disabled = false;
    const placeholder = document.createElement('option');
    placeholder.value = '';
    placeholder.disabled = true;
    placeholder.selected = true;
    placeholder.textContent = 'Choisir…';
    typeSelect.appendChild(placeholder);

    for (const t of types) {
      const opt = document.createElement('option');
      opt.value = t.value;
      opt.textContent = t.label;
      typeSelect.appendChild(opt);
    }
  });
</script>
</Base>
