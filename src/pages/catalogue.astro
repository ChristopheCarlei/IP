---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

// Valeurs uniques pour les filtres
const faculties = [...new Set(allProjects.map(p => p.data.faculty).filter(Boolean))].sort();
const categories = [...new Set(allProjects.map(p => p.data.category).filter(Boolean))].sort();
const studentCounts = ['Moins de 25', '25-75', '75-150', 'Plus de 150'];
---
<Base title="Catalogue des projets">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-2">Catalogue des projets</h1>
    <p class="text-gray-500 mb-8">{allProjects.length} projets répertoriés</p>

    <!-- Filtres -->
    <div class="bg-gray-50 rounded-xl p-6 mb-8 flex flex-wrap gap-4">
      <div class="flex flex-col gap-1">
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Faculté</label>
        <select id="filter-faculty" class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white min-w-[160px]">
          <option value="">Toutes</option>
          {faculties.map(f => <option value={f}>{f}</option>)}
        </select>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Axe pédagogique</label>
        <select id="filter-category" class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white min-w-[160px]">
          <option value="">Tous</option>
          {categories.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Nb d'étudiants</label>
        <select id="filter-students" class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white min-w-[160px]">
          <option value="">Tous</option>
          {studentCounts.map(s => <option value={s}>{s}</option>)}
        </select>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Recherche</label>
        <input id="filter-search" type="search" placeholder="Titre, auteur..." class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white min-w-[200px]" />
      </div>
      <div class="flex items-end">
        <button id="filter-reset" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-white transition">
          Réinitialiser
        </button>
      </div>
    </div>

    <!-- Compteur résultats -->
    <p id="result-count" class="text-sm text-gray-500 mb-4"></p>

    <!-- Grille projets -->
    <div id="projects-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {allProjects.map(p => (
        <a
          href={`/projets/${p.slug}`}
          class="project-card bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md transition group"
          data-faculty={p.data.faculty ?? ''}
          data-category={p.data.category ?? ''}
          data-students={p.data.students ?? ''}
          data-title={p.data.title.toLowerCase()}
          data-author={(p.data.author ?? '').toLowerCase()}
        >
          {p.data.images?.[0] && (
            <img src={p.data.images[0]} alt={p.data.title} class="w-full h-44 object-cover" loading="lazy" />
          )}
          <div class="p-5">
            <div class="flex items-start justify-between gap-2 mb-1">
              {p.data.category && (
                <span class="text-xs text-unige-red font-semibold uppercase tracking-wide shrink-0">
                  {p.data.category}
                </span>
              )}
              {p.data.status === 'archivé' && (
                <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full shrink-0">Archivé</span>
              )}
            </div>
            <h2 class="font-semibold text-gray-900 group-hover:text-unige-red transition leading-snug">{p.data.title}</h2>
            {p.data.author && <p class="text-sm text-gray-500 mt-1">{p.data.author}</p>}
            {p.data.faculty && <p class="text-xs text-gray-400 mt-1">{p.data.faculty}</p>}
            {p.data.description_short && (
              <p class="text-sm text-gray-600 mt-2 line-clamp-2">{p.data.description_short}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>

  <script>
    const cards = document.querySelectorAll('.project-card');
    const facultyEl = document.getElementById('filter-faculty');
    const categoryEl = document.getElementById('filter-category');
    const studentsEl = document.getElementById('filter-students');
    const searchEl = document.getElementById('filter-search');
    const resetBtn = document.getElementById('filter-reset');
    const countEl = document.getElementById('result-count');

    function filter() {
      const faculty = facultyEl.value;
      const category = categoryEl.value;
      const students = studentsEl.value;
      const search = searchEl.value.toLowerCase();
      let visible = 0;

      cards.forEach(card => {
        const match =
          (!faculty || card.dataset.faculty === faculty) &&
          (!category || card.dataset.category === category) &&
          (!students || card.dataset.students === students) &&
          (!search || card.dataset.title.includes(search) || card.dataset.author.includes(search));

        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      countEl.textContent = `${visible} projet${visible !== 1 ? 's' : ''} affiché${visible !== 1 ? 's' : ''}`;
    }

    [facultyEl, categoryEl, studentsEl, searchEl].forEach(el => el.addEventListener('input', filter));
    resetBtn.addEventListener('click', () => {
      facultyEl.value = '';
      categoryEl.value = '';
      studentsEl.value = '';
      searchEl.value = '';
      filter();
    });

    filter();
  </script>
</Base>
