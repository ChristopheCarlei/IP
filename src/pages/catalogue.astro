---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const faculties  = [...new Set(allProjects.map(p => p.data.faculty).filter(Boolean))].sort() as string[];
const categories = [...new Set(allProjects.map(p => p.data.category).filter(Boolean))].sort() as string[];
const years      = [...new Set(
  allProjects.map(p => p.data.year ? String(p.data.year) : null).filter(Boolean)
)].sort((a, b) => Number(b) - Number(a)) as string[];

function getFacVar(fac?: string | null): string {
  if (!fac) return 'var(--rose)';
  const f = fac.toUpperCase();
  if (f.includes('FPSE') || f.includes('PSE') || f.includes('PSYCH')) return 'var(--fac-fapse)';
  if (f.includes('GSEM'))                                               return 'var(--fac-gsem)';
  if (f.includes('FTI')  || f.includes('TRAD'))                        return 'var(--fac-fti)';
  if (f.includes('SCIEN') && !f.includes('SOC'))                       return 'var(--fac-sciences)';
  if (f.includes('MED')  || f.includes('MÉD'))                         return 'var(--fac-medecine)';
  if (f.includes('DROIT')|| f.includes('LAW'))                         return 'var(--fac-droit)';
  if (f.includes('LETTR'))                                              return 'var(--fac-lettres)';
  if (f.includes('SOC')  || f.includes('SDS'))                         return 'var(--fac-sds)';
  if (f.includes('THEO') || f.includes('THÉO'))                        return 'var(--fac-theologie)';
  return 'var(--rose)';
}
function isLightFac(fac?: string | null): boolean {
  const f = fac?.toUpperCase() ?? '';
  return f.includes('SOC') || f.includes('SDS');
}
---
<Base title="Catalogue des projets">
<style>
.page-head{background:var(--bg-soft);border-bottom:1px solid var(--line)}
.page-head-inner{width:var(--content);margin:auto;padding:clamp(36px,5vw,56px) 0 clamp(28px,4vw,40px)}
.page-head .eyebrow{margin-bottom:10px}
.page-head h1{font-size:clamp(30px,4vw,46px);line-height:1.04;letter-spacing:-.025em;font-weight:800;margin:0}
.page-head p{color:var(--muted);font-size:17px;margin:12px 0 0}

.wrap{width:var(--content);margin:auto;padding:clamp(32px,4vw,48px) 0}

.filters{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:22px;margin-bottom:28px;box-shadow:var(--shadow)}
.filters .legend{font-size:12.5px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--rose);margin:0 0 16px}
.filter-grid{display:grid;grid-template-columns:repeat(3,1fr) auto;gap:16px;align-items:end}
.filter{display:flex;flex-direction:column;gap:7px;min-width:0}
.filter label{font-size:12.5px;font-weight:800;letter-spacing:.03em;color:var(--ink)}
.filter select,.filter input{width:100%;border:1.5px solid var(--line-strong);border-radius:var(--radius-sm);padding:11px 12px;font:inherit;font-size:15px;background:#fff;color:var(--ink);outline:none;transition:border-color .15s}
.filter select:hover,.filter input:hover{border-color:var(--rose)}
.filter select:focus,.filter input:focus{border-color:var(--rose);outline:3px solid rgba(207,0,99,.25);outline-offset:0}
.reset{border:1.5px solid var(--line-strong);background:#fff;color:var(--rose);border-radius:999px;padding:11px 18px;font-weight:700;font-size:14px;cursor:pointer;font-family:var(--font);white-space:nowrap;transition:border-color .15s}
.reset:hover{border-color:var(--rose)}
.result-count{color:var(--muted);font-weight:700;font-size:15px;margin-bottom:18px}

.cards{grid-template-columns:repeat(auto-fill,minmax(288px,1fr))}
.empty{display:none;padding:48px 32px;text-align:center;border:1px dashed var(--line-strong);border-radius:var(--radius);background:var(--bg-soft);color:var(--muted)}
.empty svg{width:44px;height:44px;margin:0 auto 14px;opacity:.4;display:block}
.empty p{font-size:18px;font-weight:700;color:var(--ink);margin:0 0 12px}
.empty button{background:none;border:0;color:var(--rose);font-weight:700;font-size:15px;cursor:pointer;font-family:var(--font);text-decoration:underline}

@media(max-width:880px){.filter-grid{grid-template-columns:1fr 1fr}.reset{grid-column:1/-1}}
@media(max-width:760px){.filter-grid{grid-template-columns:1fr}}
</style>

<!-- En-tête page -->
<div class="page-head">
  <div class="page-head-inner">
    <span class="eyebrow">Catalogue</span>
    <h1>Tous les projets d'innovation</h1>
    <p>Parcourez les démarches recensées à l'Université de Genève. Filtrez par faculté, axe pédagogique ou année.</p>
  </div>
</div>

<div class="wrap">
  <!-- Filtres -->
  <div class="filters">
    <p class="legend">Filtrer les projets</p>
    <div class="filter-grid">
      <div class="filter">
        <label for="f-fac">Faculté</label>
        <select id="f-fac">
          <option value="">Toutes les facultés</option>
          {faculties.map(f => <option value={f}>{f}</option>)}
        </select>
      </div>
      <div class="filter">
        <label for="f-axe">Axe pédagogique</label>
        <select id="f-axe">
          <option value="">Tous les axes</option>
          {categories.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div class="filter">
        <label for="f-year">Année</label>
        <select id="f-year">
          <option value="">Toutes</option>
          {years.map(y => <option value={y}>{y}</option>)}
        </select>
      </div>
      <button class="reset" id="reset" type="button">Réinitialiser</button>
    </div>
    <div class="filter" style="margin-top:16px">
      <label for="f-q">Recherche libre</label>
      <input id="f-q" type="search" placeholder="Titre, enseignant·e, mot-clé…" />
    </div>
  </div>

  <p class="result-count" id="count"></p>

  <!-- Grille -->
  <div class="cards" id="grid">
    {allProjects.map(p => {
      const facVar   = getFacVar(p.data.faculty);
      const hasPhoto = !!p.data.photo;
      const light    = !hasPhoto && isLightFac(p.data.faculty);
      const searchStr = [
        p.data.title,
        p.data.author,
        p.data.category,
        p.data.innovation_type,
        p.data.faculty,
      ].filter(Boolean).join(' ').toLowerCase();

      const initials = (p.data.author ?? p.data.title ?? '').split(' ').slice(0,2).map((w: string) => w[0] ?? '').join('').toUpperCase();

      return (
        <article
          class="card"
          data-faculty={p.data.faculty ?? ''}
          data-axe={p.data.category ?? ''}
          data-year={p.data.year ? String(p.data.year) : ''}
          data-search={searchStr}
          style={`--fac:${facVar}`}
        >
          <!-- Photo ou fond couleur faculté -->
          <div
            class={`cover${!hasPhoto ? ' no-photo' + (light ? ' light' : '') : ''}`}
            style={hasPhoto ? `background-image:url(${p.data.photo})` : ''}
          >
            {!hasPhoto && <span class="cover-initials">{initials}</span>}
            {p.data.award && (
              <span class="award">
                <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor">
                  <path d="M12 2l2.4 5 5.6.6-4.2 3.8 1.2 5.6L12 19.8 6.9 17 8 11.4 3.8 7.6l5.6-.6z"/>
                </svg>
                {p.data.award}
              </span>
            )}
            {p.data.faculty && <span class="fac">{p.data.faculty}</span>}
          </div>
          <!-- Titre + auteur -->
          <div class="card-body">
            <h3><a href={`/projets/${p.slug}`}>{p.data.title}</a></h3>
            {p.data.author && <p style="color:var(--muted);font-size:13px;margin:0">{p.data.author}</p>}
          </div>
        </article>
      );
    })}
  </div>

  <div class="empty" id="empty">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 21l-6-6"/><circle cx="10" cy="10" r="7"/>
    </svg>
    <p>Aucun projet ne correspond à ces filtres.</p>
    <button id="reset2" type="button">Réinitialiser les filtres</button>
  </div>
</div>

<script>
/* Menu mobile géré par Base.astro */

/* Filtres catalogue */
(function () {
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const fac   = document.getElementById('f-fac')  as HTMLSelectElement;
  const axe   = document.getElementById('f-axe')  as HTMLSelectElement;
  const yr    = document.getElementById('f-year') as HTMLSelectElement;
  const q     = document.getElementById('f-q')    as HTMLInputElement;
  const count = document.getElementById('count')!;
  const empty = document.getElementById('empty')!;

  function apply() {
    const fv = fac.value, av = axe.value, yv = yr.value;
    const qv = q.value.trim().toLowerCase();
    let shown = 0;
    cards.forEach(c => {
      const ok =
        (!fv || c.dataset.faculty === fv) &&
        (!av || c.dataset.axe === av) &&
        (!yv || c.dataset.year === yv) &&
        (!qv || (c.dataset.search ?? '').includes(qv));
      c.style.display = ok ? 'flex' : 'none';
      if (ok) shown++;
    });
    count.textContent = shown + ' projet' + (shown !== 1 ? 's' : '') + ' affiché' + (shown !== 1 ? 's' : '');
    empty.style.display = shown ? 'none' : 'block';
  }

  function reset() { fac.value = ''; axe.value = ''; yr.value = ''; q.value = ''; apply(); }

  [fac, axe, yr, q].forEach(el => el.addEventListener('input', apply));
  document.getElementById('reset')!.addEventListener('click', reset);
  document.getElementById('reset2')!.addEventListener('click', reset);
  apply();
})();
</script>
</Base>
