---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const faculties  = [...new Set(allProjects.map(p => p.data.faculty).filter(Boolean))].sort() as string[];
const categories = [...new Set(allProjects.map(p => p.data.category).filter(Boolean))].sort() as string[];
const years      = [...new Set(allProjects.map(p => p.data.year ? String(p.data.year) : null).filter(Boolean))].sort((a, b) => Number(b) - Number(a)) as string[];

// Couleur par faculté
const facultyColors: Record<string, string> = {
  FPSE:      '#4B0B71',
  GSEM:      '#465F7F',
  FTI:       '#FF5C00',
  Sciences:  '#007E64',
  Médecine:  '#96004B',
  Droit:     '#0067C5',
  Lettres:   '#F1AB00',
  SdS:       '#00b1ae',
  Théologie: '#CF0063',
};

function facultyColor(fac?: string | null): string {
  if (!fac) return '#6B7280';
  for (const [key, val] of Object.entries(facultyColors)) {
    if (fac.toUpperCase().includes(key.toUpperCase())) return val;
  }
  return '#6B7280';
}
---
<Base title="Catalogue des projets">

  <!-- En-tête page -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 py-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-1">Catalogue des projets</h1>
      <p class="text-gray-500 text-sm">{allProjects.length} projets répertoriés</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-8">

    <!-- Filtres -->
    <div class="bg-white border border-gray-200 rounded-lg p-5 mb-8 shadow-sm">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Filtrer les projets</p>
      <div class="flex flex-wrap gap-4 items-end">

        <div class="flex flex-col gap-1 min-w-[160px]">
          <label for="filter-faculty" class="text-xs font-medium text-gray-600">Faculté</label>
          <select id="filter-faculty" class="border border-gray-300 rounded px-3 py-2 text-sm bg-white focus:ring-1 focus:ring-unige-red focus:border-unige-red outline-none">
            <option value="">Toutes les facultés</option>
            {faculties.map(f => <option value={f}>{f}</option>)}
          </select>
        </div>

        <div class="flex flex-col gap-1 min-w-[180px]">
          <label for="filter-category" class="text-xs font-medium text-gray-600">Axe pédagogique</label>
          <select id="filter-category" class="border border-gray-300 rounded px-3 py-2 text-sm bg-white focus:ring-1 focus:ring-unige-red focus:border-unige-red outline-none">
            <option value="">Tous les axes</option>
            {categories.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>

        <div class="flex flex-col gap-1 min-w-[130px]">
          <label for="filter-year" class="text-xs font-medium text-gray-600">Année</label>
          <select id="filter-year" class="border border-gray-300 rounded px-3 py-2 text-sm bg-white focus:ring-1 focus:ring-unige-red focus:border-unige-red outline-none">
            <option value="">Toutes</option>
            {years.map(y => <option value={y}>{y}</option>)}
          </select>
        </div>

        <div class="flex flex-col gap-1 flex-1 min-w-[200px]">
          <label for="filter-search" class="text-xs font-medium text-gray-600">Recherche libre</label>
          <input
            id="filter-search"
            type="search"
            placeholder="Titre, auteur, cours…"
            class="border border-gray-300 rounded px-3 py-2 text-sm bg-white focus:ring-1 focus:ring-unige-red focus:border-unige-red outline-none"
          />
        </div>

        <div class="flex gap-2 items-end pb-0.5">
          <button id="filter-reset" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded hover:bg-gray-50 transition">
            Réinitialiser
          </button>
        </div>
      </div>
    </div>

    <!-- Résultats -->
    <div class="flex items-center justify-between mb-4">
      <p id="result-count" class="text-sm text-gray-500"></p>
    </div>

    <!-- Grille projets -->
    <div id="projects-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {allProjects.map(p => {
        const fc = facultyColor(p.data.faculty);
        return (
          <a
            href={`/projets/${p.slug}`}
            class="project-card group bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow flex flex-col"
            data-faculty={p.data.faculty ?? ''}
            data-category={p.data.category ?? ''}
            data-year={p.data.year ? String(p.data.year) : ''}
            data-title={(p.data.title ?? '').toLowerCase()}
            data-author={(p.data.author ?? '').toLowerCase()}
            data-innovation={(p.data.innovation_type ?? '').toLowerCase()}
          >
            <!-- Bande couleur faculté ou image -->
            {p.data.images?.[0] ? (
              <img src={p.data.images[0]} alt={p.data.title} class="w-full h-40 object-cover" loading="lazy" />
            ) : (
              <div class="h-1.5 w-full" style={`background-color: ${fc}`} />
            )}

            <div class="p-4 flex-1 flex flex-col">
              <!-- Tags -->
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                {p.data.faculty && (
                  <span
                    class="text-[11px] font-semibold px-2 py-0.5 rounded-full text-white leading-tight"
                    style={`background-color: ${fc}`}
                  >
                    {p.data.faculty}
                  </span>
                )}
                {p.data.status === 'archivé' && (
                  <span class="text-[11px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full leading-tight">
                    Archivé
                  </span>
                )}
              </div>

              <!-- Titre -->
              <h2 class="font-semibold text-gray-900 group-hover:text-unige-red transition-colors leading-snug text-sm mb-1">
                {p.data.title}
              </h2>

              <!-- Auteur -->
              {p.data.author && (
                <p class="text-xs text-gray-500 mt-0.5">{p.data.author}</p>
              )}

              <!-- Description courte -->
              {p.data.description_short && (
                <p class="text-xs text-gray-500 mt-2 line-clamp-2 leading-relaxed">
                  {p.data.description_short}
                </p>
              )}

              <!-- Bas de carte : axe + année -->
              <div class="flex items-center justify-between mt-auto pt-3 gap-2">
                {p.data.category && (
                  <span class="text-[11px] text-gray-400 italic truncate">{p.data.category}</span>
                )}
                {p.data.year && (
                  <span class="text-[11px] text-gray-400 shrink-0">{p.data.year}</span>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Message aucun résultat -->
    <div id="no-results" class="hidden text-center py-20 text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <p class="text-lg font-medium text-gray-500">Aucun projet ne correspond à ces filtres.</p>
      <button id="reset-btn-2" class="mt-4 text-sm text-unige-red hover:underline">Réinitialiser les filtres</button>
    </div>
  </div>

  <script>
    const cards     = document.querySelectorAll<HTMLElement>('.project-card');
    const facultyEl = document.getElementById('filter-faculty')   as HTMLSelectElement;
    const categoryEl= document.getElementById('filter-category')  as HTMLSelectElement;
    const yearEl    = document.getElementById('filter-year')      as HTMLSelectElement;
    const searchEl  = document.getElementById('filter-search')    as HTMLInputElement;
    const resetBtn  = document.getElementById('filter-reset');
    const resetBtn2 = document.getElementById('reset-btn-2');
    const countEl   = document.getElementById('result-count');
    const noResults = document.getElementById('no-results');

    function resetAll() {
      facultyEl.value  = '';
      categoryEl.value = '';
      yearEl.value     = '';
      searchEl.value   = '';
      applyFilters();
    }

    function applyFilters() {
      const faculty  = facultyEl.value;
      const category = categoryEl.value;
      const year     = yearEl.value;
      const search   = searchEl.value.trim().toLowerCase();
      let visible = 0;

      cards.forEach(card => {
        const match =
          (!faculty  || card.dataset.faculty === faculty) &&
          (!category || card.dataset.category === category) &&
          (!year     || card.dataset.year === year) &&
          (!search   ||
            card.dataset.title!.includes(search) ||
            card.dataset.author!.includes(search) ||
            card.dataset.innovation!.includes(search));

        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      if (countEl) countEl.textContent = `${visible} projet${visible !== 1 ? 's' : ''} affiché${visible !== 1 ? 's' : ''}`;
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    [facultyEl, categoryEl, yearEl, searchEl].forEach(el => el?.addEventListener('input', applyFilters));
    resetBtn?.addEventListener('click', resetAll);
    resetBtn2?.addEventListener('click', resetAll);

    applyFilters();
  </script>
</Base>
