---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const activeProjects = allProjects.filter(p => p.data.status === 'actif');
const featured = allProjects.filter(p => p.data.featured).slice(0, 6);
const activeCount = activeProjects.length;

// Couleurs par faculté
const facultyColors: Record<string, string> = {
  FPSE:      '#4B0B71',
  GSEM:      '#465F7F',
  FTI:       '#FF5C00',
  Sciences:  '#007E64',
  Médecine:  '#96004B',
  Droit:     '#0067C5',
  Lettres:   '#F1AB00',
  SdS:       '#00b1ae',
  Théologie: '#CF0063',
};

function facultyColor(fac?: string): string {
  if (!fac) return '#6B7280';
  for (const [key, val] of Object.entries(facultyColors)) {
    if (fac.toUpperCase().includes(key.toUpperCase())) return val;
  }
  return '#6B7280';
}

// 4 axes pédagogiques
const axes = [
  {
    slug: 'preparer',
    label: 'Préparer',
    description: "Demander aux étudiant·es d'effectuer une tâche avant le cours",
    icon: '📖',
    color: '#0067C5',
  },
  {
    slug: 'rendre-actif',
    label: 'Rendre actif',
    description: 'Engager les étudiant·es pendant la séance',
    icon: '⚡',
    color: '#007E64',
  },
  {
    slug: 'responsabiliser',
    label: 'Responsabiliser',
    description: "Développer l'autonomie et la responsabilité",
    icon: '🎯',
    color: '#F1AB00',
  },
  {
    slug: 'faire-creer',
    label: 'Faire créer',
    description: "Inviter les étudiant·es à produire quelque chose d'original",
    icon: '✨',
    color: '#CF0063',
  },
];
---
<Base title="Accueil">

  <!-- Bannière hero UNIGE -->
  <section class="bg-unige-red text-white">
    <div class="max-w-7xl mx-auto px-4 py-14 md:py-20">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-widest opacity-80 mb-3">
          Université de Genève
        </p>
        <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4">
          Bienvenue sur la plateforme d'Innovations Pédagogiques
        </h1>
        <p class="text-lg opacity-90 mb-8 leading-relaxed">
          Découvrez <strong class="font-semibold">{activeCount}+ projets</strong> d'enseignants qui innovent
          dans leurs cours à l'Université de Genève.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/catalogue"
             class="bg-white text-unige-red font-semibold px-6 py-3 rounded hover:bg-gray-100 transition text-sm">
            Explorer le catalogue
          </a>
          <a href="/videos"
             class="border border-white/60 px-6 py-3 rounded hover:bg-white/10 transition text-sm font-medium">
            Voir les vidéos
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trois espaces : Découvrir / Explorer / Réaliser -->
  <section class="border-b border-gray-100 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-gray-200">
        <!-- Découvrir -->
        <div class="py-10 md:pr-8">
          <div class="flex items-center gap-3 mb-3">
            <span class="w-8 h-8 rounded-full bg-unige-red text-white flex items-center justify-center text-sm font-bold">1</span>
            <h2 class="text-lg font-bold text-gray-900">Découvrir</h2>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Parcourez les projets d'innovation pédagogique recensés à l'UNIGE.
            Filtrez par faculté, axe pédagogique ou type d'innovation.
          </p>
          <a href="/catalogue" class="text-sm font-semibold text-unige-red hover:underline inline-flex items-center gap-1">
            Aller au catalogue
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Explorer -->
        <div class="py-10 md:px-8">
          <div class="flex items-center gap-3 mb-3">
            <span class="w-8 h-8 rounded-full bg-unige-red text-white flex items-center justify-center text-sm font-bold">2</span>
            <h2 class="text-lg font-bold text-gray-900">Explorer</h2>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Approfondissez un axe pédagogique parmi les 4 approches qui structurent
            les innovations : Préparer, Rendre actif, Responsabiliser, Faire créer.
          </p>
          <div class="flex flex-wrap gap-2 mt-3">
            {axes.map(axe => (
              <a
                href={`/axes/${axe.slug}`}
                class="text-xs font-semibold px-3 py-1.5 rounded-full text-white transition hover:opacity-80"
                style={`background-color: ${axe.color}`}
              >
                {axe.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Réaliser -->
        <div class="py-10 md:pl-8">
          <div class="flex items-center gap-3 mb-3">
            <span class="w-8 h-8 rounded-full bg-unige-red text-white flex items-center justify-center text-sm font-bold">3</span>
            <h2 class="text-lg font-bold text-gray-900">Réaliser</h2>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Bénéficiez du soutien du SEA pour concevoir et mettre en œuvre
            votre propre projet d'innovation pédagogique.
          </p>
          <a href="/soutien" class="text-sm font-semibold text-unige-red hover:underline inline-flex items-center gap-1">
            En savoir plus
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4 axes pédagogiques -->
  <section class="max-w-7xl mx-auto px-4 py-14">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900">4 axes pédagogiques</h2>
      <a href="/catalogue" class="text-sm text-unige-red font-medium hover:underline">Voir tous les projets →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {axes.map(axe => (
        <a
          href={`/axes/${axe.slug}`}
          class="group block bg-white border border-gray-200 rounded-lg p-6 hover:shadow-md transition-shadow"
          style={`border-top: 3px solid ${axe.color}`}
        >
          <span class="text-2xl mb-3 block">{axe.icon}</span>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-unige-red transition-colors">
            {axe.label}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed">{axe.description}</p>
          <span class="mt-4 inline-block text-xs font-semibold" style={`color: ${axe.color}`}>
            Explorer →
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Projets en vedette -->
  {featured.length > 0 && (
    <section class="bg-gray-50 py-14 border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl font-bold text-gray-900">Projets mis en avant</h2>
          <a href="/catalogue" class="text-sm text-unige-red font-medium hover:underline">Tous les projets →</a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featured.map(p => {
            const fc = facultyColor(p.data.faculty);
            return (
              <a
                href={`/projets/${p.slug}`}
                class="group bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow flex flex-col"
              >
                {p.data.images?.[0] ? (
                  <img src={p.data.images[0]} alt={p.data.title} class="w-full h-44 object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-2" style={`background-color: ${fc}`} />
                )}
                <div class="p-5 flex-1 flex flex-col">
                  <div class="flex items-center gap-2 mb-2">
                    {p.data.faculty && (
                      <span class="text-xs font-semibold px-2 py-0.5 rounded-full text-white" style={`background-color: ${fc}`}>
                        {p.data.faculty}
                      </span>
                    )}
                    {p.data.category && (
                      <span class="text-xs text-gray-500">{p.data.category}</span>
                    )}
                  </div>
                  <h3 class="font-semibold text-gray-900 group-hover:text-unige-red transition-colors leading-snug mb-1">
                    {p.data.title}
                  </h3>
                  {p.data.author && (
                    <p class="text-sm text-gray-500 mt-auto pt-2">{p.data.author}</p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Bandeau chiffres clés -->
  <section class="bg-unige-red text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-4xl font-bold">{activeCount}+</p>
          <p class="text-sm opacity-80 mt-1">projets actifs</p>
        </div>
        <div>
          <p class="text-4xl font-bold">11</p>
          <p class="text-sm opacity-80 mt-1">facultés</p>
        </div>
        <div>
          <p class="text-4xl font-bold">4</p>
          <p class="text-sm opacity-80 mt-1">axes pédagogiques</p>
        </div>
        <div>
          <p class="text-4xl font-bold">∞</p>
          <p class="text-sm opacity-80 mt-1">idées à partager</p>
        </div>
      </div>
    </div>
  </section>

</Base>
