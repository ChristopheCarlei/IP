---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects.filter(p => p.data.featured).slice(0, 6);
const activeCount = allProjects.filter(p => p.data.status === 'actif').length;

const axes = [
  { slug: 'preparer', label: 'Préparer', description: 'Demander aux étudiant·es d'effectuer une tâche avant le cours', color: 'bg-blue-100 text-blue-800' },
  { slug: 'rendre-actif', label: 'Rendre actif', description: 'Engager les étudiant·es pendant la séance', color: 'bg-green-100 text-green-800' },
  { slug: 'responsabiliser', label: 'Responsabiliser', description: 'Développer l'autonomie et la responsabilité', color: 'bg-yellow-100 text-yellow-800' },
  { slug: 'faire-creer', label: 'Faire créer', description: 'Inviter les étudiant·es à produire quelque chose d'original', color: 'bg-purple-100 text-purple-800' },
];
---
<Base title="Accueil">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-unige-red to-red-800 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Innovations Pédagogiques</h1>
      <p class="text-xl opacity-90 mb-8">
        Découvrez plus de {activeCount} projets d'innovation pédagogique de l'Université de Genève
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/catalogue" class="bg-white text-unige-red font-semibold px-6 py-3 rounded-lg hover:bg-gray-100 transition">
          Explorer le catalogue
        </a>
        <a href="/videos" class="border border-white px-6 py-3 rounded-lg hover:bg-white/10 transition">
          Voir les vidéos
        </a>
      </div>
    </div>
  </section>

  <!-- 4 axes pédagogiques -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold mb-8 text-center">4 axes pédagogiques</h2>
    <div class="grid md:grid-cols-4 gap-6">
      {axes.map(axe => (
        <a href={`/axes/${axe.slug}`} class="block p-6 rounded-xl border border-gray-200 hover:shadow-md transition group">
          <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full mb-3 ${axe.color}`}>
            {axe.label}
          </span>
          <p class="text-sm text-gray-600 group-hover:text-gray-900 transition">{axe.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Projets en vedette -->
  {featured.length > 0 && (
    <section class="bg-gray-50 py-16">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-2xl font-bold mb-8">Projets en vedette</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {featured.map(p => (
            <a href={`/projets/${p.slug}`} class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md transition group">
              {p.data.images?.[0] && (
                <img src={p.data.images[0]} alt={p.data.title} class="w-full h-48 object-cover" />
              )}
              <div class="p-5">
                {p.data.category && (
                  <span class="text-xs text-unige-red font-semibold uppercase tracking-wide">{p.data.category}</span>
                )}
                <h3 class="font-semibold mt-1 group-hover:text-unige-red transition">{p.data.title}</h3>
                {p.data.author && <p class="text-sm text-gray-500 mt-1">{p.data.author}</p>}
                {p.data.faculty && <p class="text-xs text-gray-400 mt-1">{p.data.faculty}</p>}
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/catalogue" class="inline-block bg-unige-red text-white px-6 py-3 rounded-lg hover:bg-red-800 transition">
            Voir tous les projets
          </a>
        </div>
      </div>
    </section>
  )}
</Base>
