---
import Base from '../../layouts/Base.astro';

// Les valeurs restent en français : elles alimentent la même collection CMS (src/content/projects)
const facultes = [
  { value: 'Sciences', label: 'Sciences' },
  { value: 'Médecine', label: 'Medicine' },
  { value: 'Lettres', label: 'Arts (Lettres)' },
  { value: 'SDS', label: 'SDS' },
  { value: 'GSEM', label: 'GSEM' },
  { value: 'Droit', label: 'Law' },
  { value: 'Théologie', label: 'Theology' },
  { value: 'FPSE', label: 'FPSE' },
  { value: 'FTI', label: 'FTI' },
  { value: 'SEA', label: 'SEA' },
  { value: 'DISTIC', label: 'DISTIC' },
  { value: 'Rectorat', label: "Rector's office" },
  { value: 'Autre', label: 'Other' },
];
const niveaux = [
  { value: 'Bachelor', label: "Bachelor's" },
  { value: 'Master', label: "Master's" },
  { value: 'Doctorat', label: 'PhD' },
  { value: 'Formation continue', label: 'Continuing education' },
  { value: 'Tous', label: 'All levels' },
];
const effectifs = [
  { value: 'Moins de 25', label: 'Under 25' },
  { value: '25-75', label: '25–75' },
  { value: '75-150', label: '75–150' },
  { value: 'Plus de 150', label: 'Over 150' },
];
const categories = [
  { value: 'Préparer', label: 'Prepare' },
  { value: 'Rendre actif', label: 'Activate' },
  { value: 'Responsabiliser', label: 'Empower' },
  { value: 'Faire créer', label: 'Create' },
];
---
<Base title="Propose a project" lang="en" description="Submit your pedagogical innovation project for publication on the University of Geneva's Pedagogical Innovations platform.">
<style>
.pp-hero{background:#fff;border-bottom:1px solid var(--line)}
.pp-hero-inner{width:var(--content);margin:auto;padding:clamp(40px,5vw,64px) 0}
.pp-hero-eyebrow{display:inline-block;font-size:12px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--rose);margin-bottom:16px}
.pp-hero h1{font-size:clamp(36px,4.6vw,56px);line-height:1;font-weight:800;letter-spacing:-.03em;color:var(--ink);margin:0}
.pp-hero p{color:var(--muted);font-size:16.5px;line-height:1.7;max-width:72ch;margin:18px 0 0}
.pp-note{display:flex;gap:12px;align-items:flex-start;background:var(--bg-rose);border-radius:var(--radius-sm);padding:16px 18px;margin-top:24px;max-width:72ch}
.pp-note svg{width:20px;height:20px;flex-shrink:0;color:var(--rose-deep);margin-top:1px}
.pp-note p{margin:0;color:var(--rose-ink);font-size:14px;line-height:1.6}

.pp-wrap{width:var(--content);margin:auto;padding:clamp(36px,5vw,64px) 0}
form{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:clamp(24px,4vw,40px);max-width:900px}

.pp-sec{margin-bottom:32px}
.pp-sec:last-of-type{margin-bottom:0}
.pp-sec h2{font-size:13px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--rose);margin:0 0 18px;padding-bottom:10px;border-bottom:1px solid var(--line)}

.pp-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.pp-field{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
.pp-field.full{grid-column:1 / -1}
.pp-field label{font-size:13.5px;font-weight:700;color:var(--ink)}
.pp-field label .opt{font-weight:400;color:var(--faint);text-transform:none;letter-spacing:0}
.pp-field input[type="text"],
.pp-field input[type="email"],
.pp-field input[type="number"],
.pp-field input[type="url"],
.pp-field select,
.pp-field textarea{
  font-family:var(--font);font-size:15px;color:var(--ink);
  border:1.5px solid var(--line-strong);border-radius:var(--radius-sm);
  padding:10px 13px;background:#fff;width:100%;
}
.pp-field input:focus,.pp-field select:focus,.pp-field textarea:focus{
  outline:2px solid var(--rose);outline-offset:1px;border-color:var(--rose);
}
.pp-field textarea{resize:vertical;min-height:90px;line-height:1.5}
.pp-field input[type="file"]{font-size:14px;color:var(--muted)}
.pp-hint{font-size:12.5px;color:var(--faint)}

.pp-check{display:flex;align-items:flex-start;gap:10px;grid-column:1/-1}
.pp-check input{margin-top:3px;width:16px;height:16px;accent-color:var(--rose)}
.pp-check label{font-size:14px;font-weight:600;color:var(--ink)}

.pp-hp{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden}

.pp-submit{display:flex;align-items:center;gap:16px;margin-top:8px;flex-wrap:wrap}
.pp-submit .btn{padding:13px 28px;font-size:15.5px}
.pp-submit .req{font-size:13px;color:var(--faint)}

@media(max-width:680px){.pp-grid{grid-template-columns:1fr}}
</style>

<div class="pp-hero">
  <div class="pp-hero-inner">
    <span class="pp-hero-eyebrow">Pedagogical Innovations · UNIGE</span>
    <h1>Propose a project</h1>
    <p>
      Are you implementing an innovative teaching practice in your course? Describe it below so it
      can be listed on the platform.
    </p>
    <div class="pp-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      <p>
        Your submission is reviewed by the platform team before publication — it does not appear
        automatically on the site. We may get back to you for a few clarifications.
      </p>
    </div>
  </div>
</div>

<div class="pp-wrap">
  <form name="propose-project-en" method="POST" data-netlify="true" netlify-honeypot="bot-field" enctype="multipart/form-data" action="/en/thank-you-project">
    <input type="hidden" name="form-name" value="propose-project-en" />
    <p class="pp-hp"><label>Leave this empty if you are human: <input name="bot-field" /></label></p>

    <div class="pp-sec">
      <h2>Your contact details</h2>
      <div class="pp-grid">
        <div class="pp-field">
          <label for="submitter_name">Your full name *</label>
          <input type="text" id="submitter_name" name="submitter_name" required />
        </div>
        <div class="pp-field">
          <label for="submitter_email">Your e-mail *</label>
          <input type="email" id="submitter_email" name="submitter_email" required />
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>The project</h2>
      <div class="pp-grid">
        <div class="pp-field">
          <label for="title_en">Project title (EN) *</label>
          <input type="text" id="title_en" name="title_en" required />
        </div>
        <div class="pp-field">
          <label for="title">Project title (FR) <span class="opt">optional</span></label>
          <input type="text" id="title" name="title" />
        </div>
        <div class="pp-field">
          <label for="author">Project lead *</label>
          <input type="text" id="author" name="author" required />
        </div>
        <div class="pp-field">
          <label for="author_email">Project lead's e-mail <span class="opt">if different</span></label>
          <input type="email" id="author_email" name="author_email" />
        </div>
        <div class="pp-field full">
          <label for="members">Other team members <span class="opt">optional, one per line</span></label>
          <textarea id="members" name="members"></textarea>
        </div>
        <div class="pp-field">
          <label for="faculty">Faculty / unit *</label>
          <select id="faculty" name="faculty" required>
            <option value="" disabled selected>Choose…</option>
            {facultes.map(f => <option value={f.value}>{f.label}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="course">Related course</label>
          <input type="text" id="course" name="course" />
        </div>
        <div class="pp-field">
          <label for="course_code">Course code <span class="opt">optional</span></label>
          <input type="text" id="course_code" name="course_code" />
        </div>
        <div class="pp-field">
          <label for="year">Year introduced</label>
          <input type="text" id="year" name="year" placeholder="e.g. 2025" />
        </div>
        <div class="pp-field">
          <label for="level">Study level</label>
          <select id="level" name="level">
            <option value="" disabled selected>Choose…</option>
            {niveaux.map(n => <option value={n.value}>{n.label}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="students">Number of students involved</label>
          <select id="students" name="students">
            <option value="" disabled selected>Choose…</option>
            {effectifs.map(e => <option value={e.value}>{e.label}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="category">Pedagogical category</label>
          <select id="category" name="category">
            <option value="" disabled selected>Choose…</option>
            {categories.map(c => <option value={c.value}>{c.label}</option>)}
          </select>
        </div>
        <div class="pp-field">
          <label for="innovation_type">Type of innovation <span class="opt">free keywords</span></label>
          <input type="text" id="innovation_type" name="innovation_type" />
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>Description</h2>
      <div class="pp-grid">
        <div class="pp-field full">
          <label for="description_short_en">Short description (EN) * <span class="opt">2-3 sentences</span></label>
          <textarea id="description_short_en" name="description_short_en" required></textarea>
        </div>
        <div class="pp-field full">
          <label for="description_short">Short description (FR) <span class="opt">optional</span></label>
          <textarea id="description_short" name="description_short"></textarea>
        </div>
        <div class="pp-field full">
          <label for="body">Detailed description <span class="opt">process, goals, setup, feedback…</span></label>
          <textarea id="body" name="body" style="min-height:160px"></textarea>
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>Media &amp; awards</h2>
      <div class="pp-grid">
        <div class="pp-field">
          <label for="youtube">YouTube video link <span class="opt">optional</span></label>
          <input type="url" id="youtube" name="youtube" placeholder="https://youtube.com/embed/…" />
        </div>
        <div class="pp-field">
          <label for="images">Project photos <span class="opt">optional, multiple files allowed</span></label>
          <input type="file" id="images" name="images" accept="image/*" multiple />
        </div>
        <div class="pp-field">
          <label for="award">Award received <span class="opt">optional</span></label>
          <input type="text" id="award" name="award" />
        </div>
        <div class="pp-field">
          <label for="award_year">Award year <span class="opt">optional</span></label>
          <input type="text" id="award_year" name="award_year" />
        </div>
        <div class="pp-check">
          <input type="checkbox" id="observation_accepted" name="observation_accepted" value="oui" />
          <label for="observation_accepted">I agree that colleagues may observe a session of this course</label>
        </div>
      </div>
    </div>

    <div class="pp-sec">
      <h2>Additional message</h2>
      <div class="pp-field full">
        <label for="message">Anything else to add? <span class="opt">optional</span></label>
        <textarea id="message" name="message"></textarea>
      </div>
    </div>

    <div class="pp-submit">
      <button type="submit" class="btn primary">Submit my proposal</button>
      <span class="req">* required fields</span>
    </div>
  </form>
</div>
</Base>
