---
import Base from '../../../layouts/Base.astro';
import InnovationDetail from '../../../components/InnovationDetail.astro';
import { innovations, normType } from '../../../innovations';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return innovations.map(i => ({ params: { slug: i.slug }, props: { innov: i } }));
}

const { innov } = Astro.props;
const all = await getCollection('projects');
const target = normType(innov.typeFr);
const projects = all
  .filter(p => p.data.status === 'actif' && normType(p.data.innovation_type ?? '') === target)
  .slice(0, 8);
---
<Base title={innov.en} description={innov.descEn} lang="en">
  <InnovationDetail innov={innov} lang="en" projects={projects} />
</Base>
