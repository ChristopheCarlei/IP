---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', p => p.data.observation_accepted === true);
---
<Base title="Peer observation" lang="en">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-4">Peer observation</h1>
    <p class="text-xl text-gray-500 mb-8 italic">Observation between colleagues</p>

    <div class="mb-10">
      <p class="text-gray-700 mb-4">
        Have you spotted an innovation, tool or practice among the platform's projects and would
        you like to learn more about it to implement it in your courses?
      </p>
      <p class="text-gray-700">
        The teachers listed below have agreed to open the door of their classroom to UNIGE
        colleagues. Contact them directly to suggest an observation or to get more information
        about their projects.
      </p>
    </div>

    <a href="https://www.unige.ch/sea/ressources/observation-entre-pairs" target="_blank" rel="noopener"
       class="inline-block mb-8 text-sm text-unige-red hover:underline">
      → Learn more about peer observation
    </a>

    {projects.length > 0 ? (
      <div class="grid md:grid-cols-2 gap-4">
        {projects.map(p => (
          <a href={`/en/projets/${p.slug}`} class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition">
            <div>
              <p class="font-medium text-gray-900">{p.data.title}</p>
              {p.data.author && <p class="text-sm text-gray-500">{p.data.author}</p>}
              {p.data.faculty && <p class="text-xs text-gray-400">{p.data.faculty}</p>}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-500 italic">Projects open to observation will be listed here after data migration.</p>
    )}
  </div>
</Base>
