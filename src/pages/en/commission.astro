// Traduction des fonctions / rôles (mappage centralisé, repli sur le texte FR)
const FONCTION_EN: Record<string, string> = {
  "Cheffe de service": "Head of unit",
  "Chef de service": "Head of unit",
  "Informaticien de développement": "Software developer",
  "Adjoint scientifique": "Scientific officer",
  "Adjointe scientifique": "Scientific officer",
  "Secrétaire": "Secretary",
  "Technicien de production": "Production technician",
  "Organisatrice": "Organizer",
  "Professeur associé": "Associate professor",
  "Professeure associée": "Associate professor",
  "Professeur ordinaire": "Full professor",
  "Professeure ordinaire": "Full professor",
  "Collaboratrice scientifique": "Scientific collaborator",
  "Collaborateur scientifique": "Scientific collaborator",
  "Maître d'enseignement et de recherche": "Senior lecturer and researcher",
  "Maîtresse d'enseignement et de recherche": "Senior lecturer and researcher",
  "Chef de projet": "Project lead",
  "Chargée d'enseignement": "Lecturer",
  "Chargé de cours": "Lecturer",
  "Chargée de cours": "Lecturer",
  "Coordinatrice en information documentaire": "Documentary information coordinator",
  "Adjoint au rectorat": "Rectorate officer",
  "Directrice": "Director",
  "Chargé d'enseignement et coordinateur pédagogique": "Lecturer and pedagogical coordinator",
  "Doctorante et chargée d'enseignement": "PhD candidate and lecturer",
};
const ROLE_EN: Record<string, string> = {
  "Comité de pilotage Plateforme": "Platform steering committee",
  "Chef de projet Plateforme": "Platform project lead",
  "Rédactrice projets Plateforme": "Platform project writer",
  "Développeur et designer Plateforme": "Platform developer & designer",
  "Photographe Plateforme": "Platform photographer",
  "Coordinatrice prix de l'enseignement": "Teaching award coordinator",
};
const trF = (s: string) => FONCTION_EN[s] ?? s;
const trR = (s: string) => ROLE_EN[s] ?? s;

const equipe = membres.filter(m => m.fonctionIP);
const cip    = membres.filter(m => !m.fonctionIP);

function facVar(f: string): string {
  const x = (f || '').toUpperCase();
  if (x.includes('FPSE')) return 'var(--fac-fapse)';
  if (x.includes('GSEM')) return 'var(--fac-gsem)';
  if (x.includes('FTI'))  return 'var(--fac-fti)';
  if (x.includes('MÉD') || x.includes('MED')) return 'var(--fac-medecine)';
  if (x.includes('SDS'))  return 'var(--fac-sds)';
  if (x.includes('LETTR')) return 'var(--fac-lettres)';
  if (x.includes('DROIT')) return 'var(--fac-droit)';
  if (x.includes('THÉO') || x.includes('THEO')) return 'var(--fac-theologie)';
  if (x.includes('SCIEN')) return 'var(--fac-sciences)';
  return 'var(--rose)';
}
const initials = (n: string) => n.split(' ').slice(0, 2).map(s => s[0] ?? '').join('').toUpperCase();
---
<Base title="Pedagogical Innovation Commission" lang="en">
<style>
.cm-hero{background:#fff;border-bottom:1px solid var(--line)}
.cm-hero-inner{width:var(--content);margin:auto;padding:clamp(40px,5vw,64px) 0}
.cm-hero-eyebrow{display:inline-block;font-size:12px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--rose);margin-bottom:16px}
.cm-hero h1{font-size:clamp(34px,4.4vw,58px);line-height:1;font-weight:800;letter-spacing:-.03em;color:var(--ink);margin:0}
.cm-hero h1 .sub{display:block;font-weight:300;color:var(--muted);font-size:.64em}
.cm-hero p{color:var(--muted);font-size:16px;line-height:1.7;max-width:72ch;margin:18px 0 0}
.cm-axes{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:28px}
.cm-axe{background:var(--bg-soft);border:1px solid var(--line);border-radius:var(--radius);padding:18px 20px}
.cm-axe .ic{width:36px;height:36px;border-radius:9px;background:var(--bg-rose);color:var(--rose-deep);display:grid;place-items:center;margin-bottom:10px}
.cm-axe .ic svg{width:20px;height:20px}
.cm-axe h3{font-size:15px;font-weight:800;color:var(--ink);margin:0 0 4px}
.cm-axe p{font-size:13.5px;line-height:1.55;color:var(--muted);margin:0}
.cm-wrap{width:var(--content);margin:auto;padding:clamp(36px,5vw,64px) 0}
.cm-sec + .cm-sec{margin-top:52px}
.cm-sec-head{display:flex;align-items:baseline;gap:14px;margin:0 0 24px;flex-wrap:wrap}
.cm-sec-head h2{font-size:clamp(22px,2.6vw,30px);font-weight:800;letter-spacing:-.02em;color:var(--ink);margin:0}
.cm-sec-head .n{font-size:13px;font-weight:800;color:var(--rose);background:var(--bg-rose);padding:3px 10px;border-radius:999px}
.cm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:20px}
.cm-card{display:flex;flex-direction:column;background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);text-align:center}
.cm-photo{width:100%;aspect-ratio:1/1;object-fit:cover;object-position:center 20%;display:block;background:var(--fac,#ccc)}
.cm-photo.ph{display:flex;align-items:center;justify-content:center;font-size:40px;font-weight:800;color:rgba(255,255,255,.4)}
.cm-body{padding:14px 14px 16px;display:flex;flex-direction:column;flex:1}
.cm-body h3{font-size:15px;font-weight:800;color:var(--ink);margin:0 0 4px;letter-spacing:-.01em}
.cm-fonction{font-size:12.5px;color:var(--muted);line-height:1.4;margin:0 0 8px}
.cm-tags{margin-top:auto;display:flex;gap:6px;justify-content:center;flex-wrap:wrap}
.cm-fac{font-size:10.5px;font-weight:800;color:#fff;background:var(--fac,var(--rose));padding:2px 9px;border-radius:999px}
.cm-role{font-size:10.5px;font-weight:700;color:var(--rose-deep);background:var(--bg-rose);padding:2px 9px;border-radius:999px}
@media(max-width:760px){.cm-axes{grid-template-columns:1fr}}
@media(max-width:520px){.cm-grid{grid-template-columns:repeat(2,1fr)}}
</style>

<div class="cm-hero">
  <div class="cm-hero-inner">
    <span class="cm-hero-eyebrow">Pedagogical Innovations · UNIGE</span>
    <h1>Commission<span class="sub">for pedagogical innovations</span></h1>
    <p>
      The Pedagogical Innovation Commission (CIP) is an interfaculty commission supporting
      pedagogical innovations. We are a team of diverse disciplines, cultures and expertise,
      made up of staff from different faculties and common services. Together, we reflect,
      debate and critique in an atmosphere of respect, serving progressive teaching and
      stimulating learning.
    </p>

    <div class="cm-axes">
      <div class="cm-axe">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 3-1.8 5.4-4.5 6.5V17a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1v-1.5C6.8 14.4 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M9 21h6"/></svg></div>
        <h3>Reflection</h3>
        <p>Thinking about current and future pedagogical innovations.</p>
      </div>
      <div class="cm-axe">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg></div>
        <h3>Communication</h3>
        <p>Making these innovations known and valued.</p>
      </div>
      <div class="cm-axe">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
        <h3>Support</h3>
        <p>Supporting teachers' innovative projects.</p>
      </div>
    </div>
  </div>
</div>

<div class="cm-wrap">

  <section class="cm-sec">
    <div class="cm-sec-head">
      <h2>The platform team</h2>
      <span class="n">{equipe.length} members</span>
    </div>
    <div class="cm-grid">
      {equipe.map(m => (
        <article class="cm-card" style={`--fac:${facVar(m.faculte)}`}>
          {m.photo
            ? <img class="cm-photo" src={m.photo} alt={m.nom} loading="lazy" />
            : <div class="cm-photo ph">{initials(m.nom)}</div>}
          <div class="cm-body">
            <h3>{m.nom}</h3>
            <p class="cm-fonction">{trF(m.fonction)}</p>
            <div class="cm-tags">
              {m.faculte && <span class="cm-fac">{m.faculte}</span>}
              {m.fonctionIP && <span class="cm-role">{trR(m.fonctionIP)}</span>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="cm-sec">
    <div class="cm-sec-head">
      <h2>Commission members (CIP)</h2>
      <span class="n">{cip.length} members</span>
    </div>
    <div class="cm-grid">
      {cip.map(m => (
        <article class="cm-card" style={`--fac:${facVar(m.faculte)}`}>
          {m.photo
            ? <img class="cm-photo" src={m.photo} alt={m.nom} loading="lazy" />
            : <div class="cm-photo ph">{initials(m.nom)}</div>}
          <div class="cm-body">
            <h3>{m.nom}</h3>
            <p class="cm-fonction">{trF(m.fonction)}</p>
            <div class="cm-tags">
              {m.faculte && <span class="cm-fac">{m.faculte}</span>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

</div>
</Base>
